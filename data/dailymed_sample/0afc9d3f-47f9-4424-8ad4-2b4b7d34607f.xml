                                                   <code code="51727-6" codeSystem="2.16.840.1.113883.6.1" displayName="INACTIVE INGREDIENT SECTION"/>
                                                   <text>
                                                      <paragraph>Inactive ingredients</paragraph>
                                                      <paragraph>Butylene Glycol, C12-15 Alkyl Benzoate, Carbomer, Glyceryl Stearate, Helianthuus annus (sunflower) Seed Oil, Methylisothiazolinone, PEG-100 Stearate, Phenoxyethanol, Ploysorbate 80, Sodium Hydroxide, Sorbitol, Tocopheryl Acetate, Water (Aqua, Eau)</paragraph>
                                                   </text>
                                                   <effectiveTime value="20120827"/>
                                                </section>
