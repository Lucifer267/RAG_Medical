               <code code="51727-6" codeSystem="2.16.840.1.113883.6.1" displayName="INACTIVE INGREDIENT SECTION"/>
               <text>Non-Medicinal ingredients: sodium saccharin, sodium benzoate, plasdone C30, glycerin USP, propylene glycol, polysorbate 20, stepanol WA 100, phosphoric acid,
purified water, bubble gum
flavor</text>
               <effectiveTime value="20110209"/>
            </section>
         </component>
