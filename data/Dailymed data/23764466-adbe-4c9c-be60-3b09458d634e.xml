                     <code codeSystem="2.16.840.1.113883.6.1" code="34082-8" displayName="GERIATRIC USE SECTION"/>
                     <title>Geriatric Use:</title>
                     <text>
                        <paragraph>No overall differences in safety or effectiveness have been observed between elderly and younger patients.<br/>
                        </paragraph>
                     </text>
                     <effectiveTime value="20110715"/>
                  </section>
