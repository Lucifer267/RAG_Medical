                     <code codeSystem="2.16.840.1.113883.6.1" code="44425-7" displayName="STORAGE AND HANDLING SECTION"/>
                     <title>STORAGE</title>
                     <text>
                        <paragraph>Store at 8° to 27°C (46° to 80°F).</paragraph>
                        <paragraph>Store suspension upright and shake well before using.</paragraph>
