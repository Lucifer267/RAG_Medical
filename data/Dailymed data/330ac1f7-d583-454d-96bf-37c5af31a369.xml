               <code codeSystem="2.16.840.1.113883.6.1" code="34069-5" displayName="HOW SUPPLIED SECTION"/>
               <title>HOW SUPPLIED</title>
               <text>
                  <paragraph>Sterile ophthalmic suspension in 5 mL (<content styleCode="bold">NDC</content> 21695-203-05) DROP-TAINER® dispensers.</paragraph>
               </text>
               <effectiveTime value="20071018"/>
               <component>
                  <section ID="i4i_storage_id_ca6df4e1-7f1b-4b27-9f1d-e227faedaf56">
