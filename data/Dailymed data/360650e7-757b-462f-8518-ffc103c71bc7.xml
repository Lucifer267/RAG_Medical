                           <td align="left" valign="top">5 IU</td>
                           <td align="center" valign="top">50%</td>
                        </tr>
                        <tr>
                           <td align="left" valign="top">Vitamin B1 (as Thiamine HCl)</td>
                           <td align="left" valign="top">0.5 mg</td>
                           <td align="center" valign="top">71%</td>
                        </tr>
                        <tr>
                           <td align="left" valign="top">Vitamin B2 (as Riboflavin Phosphate Sodium)</td>
                           <td align="left" valign="top">0.6 mg</td>
                           <td align="center" valign="top">75%</td>
                        </tr>
                        <tr>
