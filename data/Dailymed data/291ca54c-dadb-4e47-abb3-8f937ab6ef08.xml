                        <paragraph>hallucination.</paragraph>
                     </text>
                     <effectiveTime value="20100701"/>
                  </section>
               </component>
               <component>
                  <section ID="i4i_section_id_6935f81a-474c-4c00-a3e6-d1e52007bfa8">
                     <id root="1fcb0518-2943-4e47-9e30-f5fcd7c26b36"/>
                     <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
                     <title>Skin and Appendages:</title>
                     <text>
                        <paragraph>pruritus, rash, urticaria.</paragraph>
                     </text>
                     <effectiveTime value="20100701"/>
