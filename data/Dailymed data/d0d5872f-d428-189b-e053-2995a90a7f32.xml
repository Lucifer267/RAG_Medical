               <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
               <title>MembraneBlue 0.15% - Storage and handling section.</title>
               <text>
                  <paragraph>MembraneBlue™ 0.15% is stored at 15 - 25°C (59 - 77°F). Protect from direct sunlight.</paragraph>
               </text>
               <effectiveTime value="20091130"/>
            </section>
