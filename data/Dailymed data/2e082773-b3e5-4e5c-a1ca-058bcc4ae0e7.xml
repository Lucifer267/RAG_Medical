               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <title>Ingredients:</title>
               <text>
                  <paragraph>Soybean oil, ascorbic acid, gelatin, glycerin, niacinamide, diabasic calcium phosphate, calcium pantothenate, lecithin, pyridoxineHCL, yellow wax, thiamine monitrate, riboflavin, folic acid, FD and c blue #1, FD and C red #40, FD and C yellow #6, biotin, titanium dioxide and cyanocobalamin.</paragraph>
               </text>
               <effectiveTime value="20131213"/>
            </section>
