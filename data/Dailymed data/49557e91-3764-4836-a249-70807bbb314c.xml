               <code code="50565-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - KEEP OUT OF REACH OF CHILDREN SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Keep out of reach of children.</content> Consult physician for children under 12.</paragraph>
