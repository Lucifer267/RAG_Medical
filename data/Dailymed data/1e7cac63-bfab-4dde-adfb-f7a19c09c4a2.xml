            <section ID="L1515cc9d-a878-4450-9799-1cc7328e6fdd">
               <id root="82a02259-b9d8-40a3-a9a0-9881bc9e72f9"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>WARNINGS</title>
               <text>
                  <paragraph>Caution is recommended in patients with a history of bipolar illness.</paragraph>
