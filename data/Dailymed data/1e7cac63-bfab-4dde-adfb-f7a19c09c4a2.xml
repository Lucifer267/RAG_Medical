               <code code="68498-5" codeSystem="2.16.840.1.113883.6.1" displayName="PATIENT MEDICATION INFORMATION SECTION"/>
               <title>PATIENT INFORMATION</title>
               <text>
                  <paragraph>Methaver is a prescription vitamin to be used only under licensed medical supervision.</paragraph>
               </text>
               <effectiveTime value="20151123"/>
            </section>
