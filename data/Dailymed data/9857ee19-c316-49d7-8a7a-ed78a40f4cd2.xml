                  <section ID="Lf02697e5-30d0-4822-9f68-db25da763ad1">
                     <id root="7198a5ea-b1b0-43bc-8621-ebc934fcd4c0"/>
                     <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
                     <title>Storage</title>
                     <text>
                        <paragraph>
                           <content styleCode="bold">Store in a cool dry place at 25°C (77°F); excursions permitted to 15° to 30°C (59° to 86°F).  See USP Controlled Room Temperature.</content>
                        </paragraph>
                        <paragraph>
                           <content styleCode="bold">PROTECT FROM LIGHT.</content>
                        </paragraph>
