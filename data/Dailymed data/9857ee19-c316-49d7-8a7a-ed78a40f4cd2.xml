               <component>
                  <section ID="L2fbdeaff-feec-454c-8daa-5ef460476305">
                     <id root="27c5965d-880d-414b-b646-300bf7e89d5e"/>
                     <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
                     <title>Dermatological</title>
                     <text>
                        <paragraph>Itching; transitory exanthema</paragraph>
                     </text>
