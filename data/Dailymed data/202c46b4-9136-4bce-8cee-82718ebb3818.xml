               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <text>
                  <paragraph>Do not swallow. Keep out of reach of children. Contents under pressure. Do not place in hot water or near radiators, stoves or other sources of heat. Do not puncture on incinerate container. Do not spray toward open flame. For professional use only.<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20110811"/>
            </section>
