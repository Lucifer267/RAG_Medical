            <section>
               <id root="90922c45-4020-4c36-898f-632080d30201"/>
               <code code="43685-7" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS AND PRECAUTIONS SECTION"/>
               <text>
                  <paragraph>Warnings: KEEP OUT OF REACH OF CHILDREN <br/>
                  </paragraph>
                  <paragraph>Avoid
spraying toward open flame. Store at room temperature. Do not expose to
excessive heat over 40 degrees C or 104 degrees F. Contents under
pressure. Do not puncture and incinerate. <br/>
                  </paragraph>
                  <paragraph>Do not use if seal is broken. <br/>
                  </paragraph>Rx<br/>
               </text>
               <effectiveTime value="20110206"/>
            </section>
