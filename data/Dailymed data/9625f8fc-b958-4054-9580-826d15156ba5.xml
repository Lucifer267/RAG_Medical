                  <section>
                     <id root="3f858855-2bcb-41f4-872e-f4ca038ab984"/>
                     <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
                     <title>STORAGE</title>
                     <text>
                        <paragraph>Store at controlled room temperature, 15°-30°C (59°-86°F). Protect from excessive heat or freezing.</paragraph>
                     </text>
                     <effectiveTime value="20160920"/>
                  </section>
               </component>
            </section>
