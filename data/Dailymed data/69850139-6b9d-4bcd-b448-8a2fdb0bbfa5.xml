               <id root="effc5d7b-2d13-4001-a74c-e3fefa86ebfe"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>WARNING</title>
               <text>
                  <paragraph>Keep out of reach of children. Do not use on people with known allergies to benzocaine and PABA compounds.</paragraph>
               </text>
               <effectiveTime value="20100513"/>
            </section>
