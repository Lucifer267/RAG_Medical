               <id root="4592dc36-cd8c-43d7-8bce-8eab6ae56319"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>USUAL DOSAGE</title>
               <text>
                  <paragraph>For oral mucosal use only as directed by a dentist.</paragraph>
               </text>
               <effectiveTime value="20100513"/>
            </section>
         </component>
         <component>
            <section>
               <id root="6cdc1b61-f551-4c42-ae00-23214bcf1115"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <title>CAUTION</title>
               <text>
                  <paragraph>Contains FD&amp;C Yellow #5 (tartrazine) which may cause an allergenic response. Federal law prohibits dispensing without a prescription.</paragraph>
               </text>
               <effectiveTime value="20100513"/>
            </section>
         </component>
         <component>
