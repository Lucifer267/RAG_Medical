            <section ID="i4i_section_id_42747aee-ee8e-46e5-903e-736c2e34cf8d">
               <id root="e1a9d580-3a7a-4372-96ab-4c8c6330b7ed"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">FOR DERMATOLOGIC USE ONLY.</content>
                     <br/>
                     <content styleCode="bold">NOT FOR USE IN EYES.</content>
                  </paragraph>
               </text>
               <effectiveTime value="20090918"/>
            </section>
