            <section ID="i4i_section_id_b8548f5a-9c57-4a18-b2ea-8c72c1373ed0">
               <id root="cdc7959c-74e5-4fed-8ae7-6def5002948a"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Storage:</content> Store upright between 15°to 25°C (59°to77°F). <content styleCode="bold">DO NOT FREEZE</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">Keep out of reach of children.</content>
                  </paragraph>
               </text>
               <effectiveTime value="20200501"/>
            </section>
         </component>
