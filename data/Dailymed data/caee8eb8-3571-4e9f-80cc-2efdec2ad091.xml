               <text>
                  <paragraph>Denti-Care</paragraph>
                  <paragraph>Denti-Foam <br/>
                  </paragraph>
                  <paragraph>Topical Fluoride Foam Orange<br/>
                  </paragraph>
                  <paragraph>1.23 % Fluoride Ions</paragraph>
                  <paragraph>4.4 oz / 125 g<br/>
                  </paragraph>
                  <paragraph>NDC 64778-1377-1 <br/>
                  </paragraph>
                  <paragraph>
                     <br/>
                  </paragraph>
               </text>
