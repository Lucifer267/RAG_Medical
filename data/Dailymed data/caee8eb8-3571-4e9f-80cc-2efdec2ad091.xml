         <component>
            <section>
               <id root="9c1f8500-cdc9-4bd9-9c16-948af27b3813"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <text>
                  <br/>
                  <paragraph/>
                  <paragraph>
                     <br/>
                  </paragraph>
                  <paragraph>A topical anti-caries preparation</paragraph>
                  <paragraph>Directions (for professional use only): <br/>
                  </paragraph>
                  <paragraph>1.	Use after thorough prophylaxis <br/>
                  </paragraph>
                  <paragraph>2.	To dispense, shake bottle vigorously then invert applicator 180 degrees downward to the bottom of the tray(s) <br/>
                  </paragraph>
                  <paragraph>Note: fill tray(s) at one quarter full to allow foam to expand <br/>
                  </paragraph>
                  <paragraph>3.	Insert tray(s) in mouth and have patient bite down lightly for 1 minute or up to 4 minutes <br/>
                  </paragraph>
                  <paragraph>4.	Remove tray(s) and have patient expectorate excess <br/>
                  </paragraph>
                  <paragraph>5.	Advise patient not to eat, drink or rinse for 30 minutes after the application <br/>
                  </paragraph>
                  <paragraph>130 applications</paragraph>
                  <paragraph>Medicinal ingredients:</paragraph>Fluoride ions 1.23 % w/w (from 1.76 % sodium fluoride and 1.04% hydrofluoric acid)<paragraph>
                     <br/>
                     <br/>
                  </paragraph>
                  <paragraph/>
               </text>
               <effectiveTime value="20110209"/>
            </section>
         </component>
