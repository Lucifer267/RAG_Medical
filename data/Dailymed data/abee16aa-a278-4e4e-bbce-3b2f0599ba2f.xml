               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title/>
               <text>
                  <paragraph>NDC: 51655-500-52</paragraph>
                  <paragraph>MFG: 0378-6689-10</paragraph>
                  <paragraph>Pantoprazole Sodium Delayed Release 40 MG</paragraph>
                  <paragraph>30 Tablets</paragraph>
                  <paragraph>Rx only</paragraph>
                  <paragraph>Lot#:</paragraph>
                  <paragraph>Exp. Date:</paragraph>
                  <paragraph>Each film-coated tabler contains: pantoprazole sodium, USP equivalent to 40 mg of pantoprazole</paragraph>
                  <paragraph>Dosage: See package insert</paragraph>
                  <paragraph>Store at 66-77 degrees F.</paragraph>
                  <paragraph>Store in a tight, light-resistant container (See USP). Keep out of the reach of children.</paragraph>
                  <paragraph>Mfg for: Mylan Pharmaceuticals Inc. Morgantown, WV 26505 USA Made in India Lot#:</paragraph>
                  <paragraph>Repackaged by: Northwind Pharmaceuticals, Indianapolis, IN 46256</paragraph>
                  <paragraph>
