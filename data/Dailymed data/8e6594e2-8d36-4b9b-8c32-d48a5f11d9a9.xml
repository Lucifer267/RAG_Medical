               <title>Inactive ingredients  </title>
               <text>
                  <paragraph>colloidal silicon dioxide, croscarmellose sodium,  hypromellose, lactose monohydrate, magnesium stearate, microcrystalline cellulose, polyethylene glycol, titanium dioxide</paragraph>
               </text>
               <effectiveTime value="20141024"/>
            </section>
         </component>
