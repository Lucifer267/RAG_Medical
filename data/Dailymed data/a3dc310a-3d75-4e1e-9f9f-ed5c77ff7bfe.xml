            <section ID="i4i_section_id_3f9e62eb-4570-4d8c-a0df-e4373bccc3e1">
               <id root="bff0b33a-5233-460f-9118-ffaae66d79c5"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
