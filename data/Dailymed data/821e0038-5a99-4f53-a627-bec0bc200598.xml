            <section>
               <id root="0981de33-8da2-4991-92e8-20a6e0a82c87"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Dental Rinse</content>
                  </paragraph>
               </text>
               <effectiveTime value="20130128"/>
            </section>
