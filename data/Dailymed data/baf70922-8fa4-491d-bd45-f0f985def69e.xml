               <title>HOW SUPPLIED</title>
               <text>
                  <paragraph>Luvira is supplied as clear yellowish Softgel capsule dispensed in white HDPE plastic bottles of 90ct.<br/>69336-349-90</paragraph>
               </text>
               <effectiveTime value="20200117"/>
