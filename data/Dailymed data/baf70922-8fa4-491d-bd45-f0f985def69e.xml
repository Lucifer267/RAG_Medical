         <component>
            <section ID="L4727b7f6-93b2-4d34-a71c-90756cb06c22">
               <id root="ed4f32ec-ff10-454f-b7bc-d0745b100c64"/>
               <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
               <title>STORAGE AND HANDLING</title>
               <text>
                  <paragraph>Store at controlled room temperature 15°-30°C (59°F-86°F). Keep in cool dry place. Call your doctor about side effects. You may report side effects to FDA at 1-800-FDA-1088. KEEP THIS OUT OF THE REACH OF CHILDREN.</paragraph>
                  <paragraph>
                     <content styleCode="bold">Reserved for Professional Recommendation</content>
                     <br/>All prescriptions using this product shall be pursuant to state statutes as applicable. This is not an Orange Book product. This product may be administered only under a physician’s supervision. There are no implied or explicit claims on therapeutic equivalence.</paragraph>
                  <paragraph>
                     <content styleCode="bold">Manufactured for:</content>
                     <br/>Sterling-Knight Pharmaceuticals, LLC<br/>Ripley, MS 38663<br/>Item 34990<br/>Rev. 0620-1</paragraph>
               </text>
               <effectiveTime value="20200117"/>
            </section>
