            <section ID="id_link_41612fe8-6156-1292-e054-00144ff88e88">
               <id root="9c9ae05a-bccd-79b6-e053-2a95a90a88ca"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <title>SPL UNCLASSIFIED SECTION</title>
               <text>
                  <paragraph>Rx only</paragraph>
               </text>
               <effectiveTime value="20030129"/>
            </section>
