               <code code="34089-3" codeSystem="2.16.840.1.113883.6.1" displayName="DESCRIPTION SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Purpose</content>
                  </paragraph>
                  <paragraph>Allantoin 2.00 %  ........ Skin Protectant</paragraph>
                  <paragraph>Lidocaine 4.00 % ........ Topical Anesthetic</paragraph>
                  <paragraph>Petrolatum 30.00 %..... Skin Protectant<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20150408"/>
