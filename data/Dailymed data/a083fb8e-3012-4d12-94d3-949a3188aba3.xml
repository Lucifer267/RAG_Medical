               <code codeSystem="2.16.840.1.113883.6.1" code="51945-4" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title ID="inv-6cecd5e8-ad60-414a-9fd8-cd1d23699f98">CONTAINER TEXT DISPLAYED</title>
               <text ID="inv-0c4b9277-9fb3-4eea-92a9-37f6bb55a64b">
                  <renderMultiMedia ID="ID0E5DAC" referencedObject="mm-e0e1ae41-673a-4a89-bae1-193b7a6c8baf">
                     <caption ID="inv-27861f5f-e3aa-4e5e-ab53-b55adcb989ff">Anticoagulant Sodium Citrate Bag Text</caption>
                  </renderMultiMedia>
                  <paragraph ID="inv-2581f86a-7390-4679-9eb9-6ba190eb0308">ANTICOAGULANT SODIUM CITRATE SOLUTION, USP</paragraph>
                  <paragraph ID="inv-dc82e838-a491-450a-92bc-0c7b8295fc3f">250 mL                            Code 798-60</paragraph>
                  <paragraph ID="inv-bcef1861-db1b-4d81-aecc-dcdd9ebd624c">For use with automated plasmapheresis equipment only.  Each 250 mL of anticoagulant contains 10.0 g sodium citrate (dihydrate), USP (pH adjusted with citric acid, USP).</paragraph>
                  <paragraph ID="inv-298743eb-6644-47fc-a2bb-731dd374f987">CAUTION: Not for direct intravenous infusion.</paragraph>
                  <paragraph ID="inv-987c88e0-0c73-4603-88cd-bb2993e61f11">Do not use unless anticoagulant is clear. This unit should be used for plasmapheresis only. Sterile, nonpyrogenic fluid path. Sterilized by steam. Rx Only.</paragraph>
                  <paragraph ID="inv-641e31a8-9522-4aec-ae26-031e3f2eca6d">DO NOT VENT.</paragraph>
               </text>
               <effectiveTime value="20110520"/>
