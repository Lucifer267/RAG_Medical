         <component>
            <section ID="inv-249a90ad-59fd-4f1d-8f7f-724313e0b36c">
               <id root="4927ef75-cfdc-4aaa-8ad1-ca9a39f7dc28"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="34089-3" displayName="DESCRIPTION SECTION"/>
               <title ID="inv-3b927b61-a2e3-452f-8bb8-e7a333176b56">ANTICOAGULANT SODIUM CITRATE SOLUTION, USP</title>
               <text ID="inv-17ddc1fd-ea65-4e6a-a5a0-b1e41e0bf50a">
                  <paragraph ID="inv-27dfb8fd-2bbc-452f-8505-8a2aeb0f9887">Sterile, non-pyrogenic fluid path. Sterilized by steam.</paragraph>
                  <paragraph ID="inv-1d0f7433-bd59-4ee5-b149-b85e4ac792d4">
                     <content styleCode="bold">Rx only.</content>
                  </paragraph>
                  <paragraph ID="inv-051707ce-4975-46c1-b57f-55c2a8260d84">250 ml volume bag.  </paragraph>
                  <paragraph ID="inv-0896d183-c5e2-45c8-bb92-aba82eecaa9b">Store at room temperature.</paragraph>
               </text>
               <effectiveTime value="20110520"/>
            </section>
         </component>
         <component>
            <section ID="inv-d4f58bf3-473c-4fe8-ac95-c918a459caea">
               <id root="e43f936a-4335-4adf-a7b4-b34e2338ce8a"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="34067-9" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <title ID="inv-d710fd3c-3e6a-42e6-ab91-ea602e66d212">INDICATIONS AND USAGE</title>
               <text ID="inv-25541039-ecb2-40b0-b241-0d49e3ae63e7">
                  <paragraph ID="inv-a9fa190f-c1b7-4088-b9b8-92e170319543">For use with automated plasmapheresis equipment only.  Use according to equipment manufacturer’s instructions.  This unit should be used for plasmapheresis only.</paragraph>
               </text>
               <effectiveTime value="20110520"/>
            </section>
         </component>
         <component>
            <section ID="inv-e8b16011-ddfb-4b1b-a4f7-b0b8639f0a2e">
               <id root="dea03e3f-71be-47b3-8d41-befd2dd3f4bd"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="34071-1" displayName="WARNINGS SECTION"/>
               <title ID="inv-792fcf15-d0d4-453d-871b-f97d457c06a9">WARNINGS</title>
               <text ID="inv-68d0545e-8e12-43a1-ae90-58ac84a4671c">
                  <paragraph ID="inv-d0a3ffcc-9619-402c-ad90-ef10998a8b07">Not for direct intravenous infusion.</paragraph>
                  <paragraph ID="inv-9091078c-5a7f-4f52-847c-10891d360552">DO NOT VENT.</paragraph>
                  <paragraph ID="inv-a89f9dcf-fb8d-4b27-a2cb-d6a67a1ddadd">Avoid excessive heat.  Protect from freezing.</paragraph>
               </text>
               <effectiveTime value="20110520"/>
            </section>
         </component>
         <component>
            <section ID="inv-86d49094-21a9-4968-9594-9ca1735e7a57">
               <id root="6379ce72-b144-48f6-890f-ba6787927381"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="42232-9" displayName="PRECAUTIONS SECTION"/>
               <title ID="inv-0aff6b77-b8d4-4ff0-8888-e8407c301c1d">GENERAL PRECAUTIONS</title>
               <text ID="inv-eddaa229-6cff-4c7b-88d1-9bb2c74035d2">
                  <paragraph ID="inv-15eaaa0b-b69a-42ba-8713-e89ca4f61816">Do not use unless solution is clear and no leaks are detected.</paragraph>
                  <paragraph ID="inv-0d95083f-01c8-4b1d-8b0e-5ceabb1d144a">Discard unused portion.</paragraph>
               </text>
               <effectiveTime value="20110520"/>
            </section>
         </component>
         <component>
            <section ID="inv-d8af0109-2c4d-43ed-b57c-4945731e5105">
               <id root="812b90d0-58d0-435c-9798-3c3b95f87c08"/>
