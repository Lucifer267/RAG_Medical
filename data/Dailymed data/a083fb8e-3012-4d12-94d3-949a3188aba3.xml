               <text ID="inv-602f9d6f-c5d4-49f4-a6a1-4d444b85c0bd">
                  <paragraph ID="inv-05b2deb2-bb2b-4dd1-a75a-d91b1280962a">Single Use Container.</paragraph>
               </text>
               <effectiveTime value="20110520"/>
            </section>
         </component>
