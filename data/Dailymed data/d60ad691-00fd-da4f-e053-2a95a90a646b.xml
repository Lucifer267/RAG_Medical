               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <title>Active Ingredient:</title>
               <text>
                  <paragraph>Fluoride Ion 1.23%. A stable thixotropic gel providing 1.23% fluoride ion. Available from 2.09% Sodium Fluoride and Hydrofluoric Acid.</paragraph>
               </text>
