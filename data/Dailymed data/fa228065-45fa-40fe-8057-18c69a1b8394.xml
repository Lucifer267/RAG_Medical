               <code code="51727-6" codeSystem="2.16.840.1.113883.6.1" displayName="INACTIVE INGREDIENT SECTION"/>
               <title>
                  <content styleCode="bold">Inactive Ingredients</content>
               </title>
               <text>
                  <paragraph styleCode="First">Aloe, Water, Cholesterol, Isopropyl Myristate, Aqua Caprylic/Capric Triglyceride, Propylene Glycol, Hydrogenated Phosphatidylcholine,
   Glyceryl Stearate, PEG-100 Stearate, Arginine HCL, Ethyl Oleate, Propylene Glycol, Tocophersolan, Cetyl Alcohol, Triethanolamine,
   Xanthan Gum, Tocopherol, Allantoin, Aloe Barbadensis Leaf, Methylisothiazolinone, Methyl Nicotinate.
</paragraph>
               </text>
               <effectiveTime value="20120307"/>
            </section>
