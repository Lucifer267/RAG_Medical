               <code code="69763-1" codeSystem="2.16.840.1.113883.6.1" displayName="DISPOSAL AND WASTE HANDLING"/>
               <title>DISPOSAL:</title>
               <text>
                  <paragraph>Expired or unused applicators may be disposed of according to applicable federal, state and local regulations.</paragraph>
               </text>
               <effectiveTime value="20191203"/>
            </section>
         </component>
