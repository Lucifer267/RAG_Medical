               <title>
                  <content>
                     <content styleCode="bold">﻿Warnings</content>
                  </content>
               </title>
               <text>
                  <paragraph>External Use Only</paragraph>
                  <paragraph>Avoid contact with the eyes</paragraph>
               </text>
               <effectiveTime value="20121003"/>
            </section>
         </component>
         <component>
