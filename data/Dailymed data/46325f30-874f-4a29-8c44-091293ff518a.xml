         <component>
            <section>
               <id root="811c762b-2222-4a37-ad43-776a9566b7bc"/>
               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>PRINCIPAL DISPLAY PANEL - 60 Cloth Packet Carton</title>
               <text>
                  <paragraph>NDC 42546-016-60<br/>Rx only</paragraph>
                  <paragraph>
                     <content styleCode="bold">BenzePrO<sup>®</sup>
                     </content>
