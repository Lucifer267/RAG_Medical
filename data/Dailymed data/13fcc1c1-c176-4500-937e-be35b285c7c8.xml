               <id root="ef2070c6-4d7c-41c6-8de5-96a21f9e2051"/>
               <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
               <text>
                  <paragraph>Store at room temperature, approximately 15°-30°C (59°-86°F), avoid excessive heat, light and moisture.</paragraph>
               </text>
               <effectiveTime value="20140721"/>
            </section>
