            <section ID="i4i_section_id_67e129c6-cd49-40e9-9034-5adc64299459">
               <id root="ac432f10-0600-45b8-b754-7614ecb4d889"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">For Dermatologic Use Only<br/>Not for Ophthalmic, Oral or Intravaginal Use</content>
