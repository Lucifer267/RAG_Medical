                     <id root="26869b44-ea7d-25f4-e054-00144ff8d46c"/>
                     <code code="55105-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - PURPOSE SECTION"/>
                     <title>
                        <content styleCode="italics">Purpose</content>
                     </title>
                     <text>
                        <paragraph>Antiseptic</paragraph>
                     </text>
                     <effectiveTime value="20150827"/>
                  </section>
