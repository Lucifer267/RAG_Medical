               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>DOSAGE AND ADMINISTRATION</title>
               <text>
                  <paragraph>Apply a thin film of Clindamycin Phosphate Topical Solution, Clindamycin Phosphate Lotion, or Clindamycin Phosphate Gel twice daily to affected area.</paragraph>
                  <paragraph>Lotion: Shake well immediately before using.</paragraph>
                  <paragraph>Keep all liquid dosage forms in containers tightly closed.</paragraph>
               </text>
               <effectiveTime value="20140812"/>
            </section>
