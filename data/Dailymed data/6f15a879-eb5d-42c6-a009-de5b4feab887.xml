               <code code="34088-5" codeSystem="2.16.840.1.113883.6.1" displayName="OVERDOSAGE SECTION"/>
               <title>OVERDOSAGE</title>
               <text>
                  <paragraph>Topically applied Clindamycin Phosphate can be absorbed in sufficient amounts to produce systemic effects (see <content styleCode="bold">
                        <content styleCode="underline">
                           <linkHtml href="#s6">WARNINGS</linkHtml>
                        </content>
                     </content>).</paragraph>
               </text>
               <effectiveTime value="20200123"/>
            </section>
