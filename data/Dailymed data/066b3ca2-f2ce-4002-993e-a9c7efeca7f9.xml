               <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
               <title>Storage and Handling</title>
               <text>
                  <list listType="unordered">
                     <item>Store at 59° – 86° F (15° – 30° C)</item>
                     <item>Protect from freezing</item>
                     <item>Product is free of gluten, soy milk, egg, peanut, and tree nut products</item>
                  </list>
               </text>
               <effectiveTime value="20210630"/>
            </section>
