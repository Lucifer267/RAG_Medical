               <code code="51727-6" codeSystem="2.16.840.1.113883.6.1" displayName="INACTIVE INGREDIENT SECTION"/>
               <title>Inactive Ingredients</title>
               <text>
                  <paragraph>Citric acid, FD&amp;C Red No. 40 (C.I. 16035), Flavor, Hydrofluoric Acid, Magnesium Aluminum Silicate, Phosphoric Acid, Polysorbate 20, Purified Water, Sodium Benzoate, Sodium Saccharine, Sweetness enhancer, Titanium dioxide, Tocopherol acetate, Xanthan gum, Xylitol</paragraph>
               </text>
