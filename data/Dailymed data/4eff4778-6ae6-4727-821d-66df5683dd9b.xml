               <code codeSystem="2.16.840.1.113883.6.1" code="34069-5" displayName="HOW SUPPLIED SECTION"/>
               <title>HOW SUPPLIED</title>
               <text>
                  <paragraph>
                     <content styleCode="bold">Desonide Cream 0.05% </content>is supplied in 15 g (NDC 21695-944-15) tubes.</paragraph>
               </text>
               <effectiveTime value="20100916"/>
               <component>
                  <section ID="i4i_storage_id_804871f0-f3e8-4775-b922-4237b30aefd0">
                     <id root="e3f56ad0-f740-4e89-976d-62cdea0e0f7f"/>
                     <code codeSystem="2.16.840.1.113883.6.1" code="44425-7" displayName="STORAGE AND HANDLING SECTION"/>
                     <title>Storage conditions</title>
                     <text>
                        <paragraph>
                           <content styleCode="bold">Store at 20°- 25°C (68°- 77°F). </content>[see USP Controlled Room Temperature].</paragraph>
                        <paragraph>Protect from freezing.</paragraph>
                     </text>
                     <effectiveTime value="20100916"/>
                  </section>
               </component>
            </section>
