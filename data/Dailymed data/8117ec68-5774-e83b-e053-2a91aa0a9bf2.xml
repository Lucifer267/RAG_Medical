               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>Directions</title>
               <text>
                  <paragraph> Directions: hold inhalant away from face and crush between thumb and forefinger. Carefully approach crushed inhalant to nostrils of affected person.</paragraph>
               </text>
               <effectiveTime value="20120828"/>
            </section>
