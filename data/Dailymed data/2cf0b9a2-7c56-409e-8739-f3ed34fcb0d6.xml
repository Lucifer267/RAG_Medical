            <section ID="s1">
               <id root="e5e5fb7d-89a8-44dc-8e56-b734bfe85b35"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>STERILE
</paragraph>
                  <paragraph>Rx Only
</paragraph>
               </text>
