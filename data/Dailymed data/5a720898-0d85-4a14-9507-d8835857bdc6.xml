               <code code="42232-9" codeSystem="2.16.840.1.113883.6.1" displayName="PRECAUTIONS SECTION"/>
               <title>PRECAUTIONS</title>
               <text>
                  <paragraph>Use only if solution is clear and container and seal are intact.</paragraph>
               </text>
               <effectiveTime value="20210809"/>
