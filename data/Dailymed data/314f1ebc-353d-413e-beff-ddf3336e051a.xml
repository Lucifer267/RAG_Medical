               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <text>
                  <paragraph>Avoid contact with eyes, if they do wash with water. If swallowed contact a physician immediately</paragraph>
               </text>
               <effectiveTime value="20120805"/>
