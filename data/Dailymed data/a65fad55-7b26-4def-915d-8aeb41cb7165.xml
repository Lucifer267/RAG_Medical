               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>DOSAGE AND ADMINISTRATION</title>
               <text>
                  <paragraph>Apply a thin film of clindamycin phosphate topical solution twice daily to affected area</paragraph>
                  <paragraph>Keep all liquid dosage forms in containers tightly closed.</paragraph>
               </text>
