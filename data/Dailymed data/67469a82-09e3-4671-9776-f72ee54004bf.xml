               <id root="6d3fe6d5-6b20-4c9d-a36c-790692e27bdf"/>
               <code code="34089-3" codeSystem="2.16.840.1.113883.6.1" displayName="DESCRIPTION SECTION"/>
               <text>
                  <list listType="ordered" ID="i4cd5ea33-6c66-46f5-8c87-44ba2ecad19e">
                     <item>RX Only</item>
                  </list>
                  <paragraph>For Prescription Compounding Only</paragraph>
                  <br/>Tramapap Kit<br/>Tramadol HCl and Acetaminophen Compound Kit<br/>
                  <br/>Description<br/>
                  <br/>Each Tramapap Kit is comprised of 15 grams of tramadol hydrochloride powder and  75 grams of acetaminophen powder.<br/>
                  <br/>Certificate of Analysis on File<br/>
                  <br/>Tramapap Kit also contains 23.25 grams of Lactose Monohydrate (Spray dried) powder and 1.5 grams of<br/>riboflavin USP powder. When compounded, the final product provides a homogeneous product of 300 <br/>capsules each capsule containing 50mg of tramadol and 250mg of acetaminophen.<br/>
               </text>
               <effectiveTime value="20100409"/>
            </section>
         </component>
