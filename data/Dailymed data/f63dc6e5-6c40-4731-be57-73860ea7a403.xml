               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Fluorescein Sodium Ophthalmic Strips U.S.P.</content> diagnostic agent is for professional use only</paragraph>
                  <paragraph>Each strip is impregnated with 0.6 mg of fluorescein sodium USP.</paragraph>
               </text>
