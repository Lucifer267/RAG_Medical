         <component>
            <section>
               <id root="0af10775-0031-4176-afcc-e3430967c93c"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <title>INSTRUCTIONS FOR OPENING STERILE GLOSTRIPS<sup>®</sup>
               </title>
               <text>
                  <table width="75%">
                     <colgroup>
                        <col valign="top" align="left" width="75%"/>
                        <col valign="top" align="right" width="25%"/>
                     </colgroup>
                     <tbody>
                        <tr styleCode="First Last">
                           <td align="left">1.Grasp free tab ends of wrapping and slowly pull apart. When the white paper handle becomes visible, remove the GloStrip<sup>®</sup> from the envelope.</td>
                           <td align="right">
                              <renderMultiMedia referencedObject="MM1"/>
                           </td>
                        </tr>
                     </tbody>
                  </table>
                  <paragraph/>
               </text>
               <effectiveTime value="20191223"/>
               <component>
                  <observationMedia ID="MM1">
                     <text>Figure 1</text>
                     <value xsi:type="ED" mediaType="image/jpeg">
                        <reference value="glostrips01.jpg"/>
                     </value>
                  </observationMedia>
               </component>
               <component>
                  <section>
                     <id root="f1d9789e-33f3-4279-b65c-251cd2120e27"/>
                     <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
                     <title>An Alternate Method of Opening</title>
                     <text>
                        <table width="75%">
                           <colgroup>
                              <col valign="top" align="left" width="75%"/>
                              <col valign="top" align="right" width="25%"/>
                           </colgroup>
                           <tbody>
                              <tr>
                                 <td align="left">1.Grasp envelope firmly with two hands as shown in Fig. 2 below. Tear the envelope from both its edges to the strip handle.</td>
                                 <td align="right">
                                    <renderMultiMedia referencedObject="MM2"/>
                                 </td>
                              </tr>
                              <tr>
                                 <td align="left">2.<paragraph ID="fig3">Hold the handle end of the GloStrip<sup>®</sup> with the left hand and the paper envelope without holding the tip with the right hand. See<linkHtml href="#fig3"> Fig. 3</linkHtml>
                                    </paragraph>
                                 </td>
                                 <td align="right">
                                    <renderMultiMedia referencedObject="MM3"/>
                                 </td>
                              </tr>
                              <tr>
                                 <td align="left">3.<paragraph ID="fig4">Separate the envelope at the tear, exposing the GloStrip<sup>®</sup> tip. See<linkHtml href="#fig4"> Fig. 4</linkHtml>
                                    </paragraph>
                                 </td>
                                 <td align="right">
                                    <renderMultiMedia referencedObject="MM4"/>
                                 </td>
                              </tr>
                           </tbody>
                        </table>
                        <paragraph/>
                     </text>
                     <effectiveTime value="20191223"/>
                     <component>
                        <observationMedia ID="MM2">
                           <text>Figure 2</text>
                           <value xsi:type="ED" mediaType="image/jpeg">
                              <reference value="glostrips02.jpg"/>
                           </value>
                        </observationMedia>
                     </component>
                     <component>
                        <observationMedia ID="MM3">
                           <text>Figure 3</text>
