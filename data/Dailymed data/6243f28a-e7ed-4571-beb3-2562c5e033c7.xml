            <section ID="i4i_description_id_8d7f151a-c0cd-4305-a170-5f54bf10d29c">
               <id root="ed8675fa-1a21-4812-885f-987647d7edd5"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="34089-3" displayName="DESCRIPTION SECTION"/>
               <title>DESCRIPTION:</title>
               <text>
                  <paragraph>Each 5 mL (one teaspoonful) for oral administration contains:</paragraph>
                  <paragraph>Phenobarbital, USP.......................................................16.2 mg</paragraph>
                  <paragraph>  (<content styleCode="bold">WARNING: </content> May be habit forming)</paragraph>
                  <paragraph>Hyoscyamine sulfate, USP.........................................0.1037 mg</paragraph>
                  <paragraph>Atropine sulfate, USP.................................................0.0194 mg</paragraph>
                  <paragraph>Scopolamine hydrobromide, USP................................0.0065  mg</paragraph>
                  <paragraph>Alcohol...............................................................................23%</paragraph>
               </text>
               <effectiveTime value="20110519"/>
            </section>
