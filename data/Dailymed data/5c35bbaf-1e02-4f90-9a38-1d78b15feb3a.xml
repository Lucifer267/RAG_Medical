               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>USUAL DOSAGE</title>
               <text>
                  <paragraph>For oral mucosal use only as directed by a dentist.</paragraph>
               </text>
               <effectiveTime value="20150501"/>
            </section>
         </component>
         <component>
            <section>
               <id root="84929964-2a9d-4124-94e4-53aa233497fa"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>WARNING</title>
               <text>
                  <paragraph>Keep out of the reach of children. Store at controlled room temperature 59°-86°F (15°-30°C). Do not use on people with known allergies to benzocaine and PABA compounds.</paragraph>
               </text>
               <effectiveTime value="20150501"/>
            </section>
