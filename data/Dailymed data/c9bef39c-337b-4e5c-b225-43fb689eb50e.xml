               <code code="34070-3" codeSystem="2.16.840.1.113883.6.1" displayName="CONTRAINDICATIONS SECTION"/>
               <title>4 CONTRAINDICATIONS</title>
               <text>
                  <paragraph/>
                  <paragraph>Patients with hypercalcemia.</paragraph>
               </text>
               <effectiveTime value="20140119"/>
               <excerpt>
                  <highlight>
                     <text>
                        <paragraph>• Hypercalcemia.</paragraph>
