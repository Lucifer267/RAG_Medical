               <code code="43678-2" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE FORMS &amp; STRENGTHS SECTION"/>
               <title>3 DOSAGE FORMS AND STRENGTHS</title>
               <text>
                  <paragraph/>
                  <paragraph>Capsule: 667 mg calcium acetate per capsule.</paragraph>
               </text>
               <effectiveTime value="20140119"/>
               <excerpt>
                  <highlight>
                     <text>
                        <paragraph>• Capsule: 667 mg calcium acetate capsules.</paragraph>
                     </text>
                  </highlight>
               </excerpt>
            </section>
         </component>
