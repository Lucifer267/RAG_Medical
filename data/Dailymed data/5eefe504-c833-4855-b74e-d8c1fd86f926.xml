         <component>
            <section ID="L6338a093-a282-4b80-af43-f248c1d07830">
               <id root="361621bb-5f75-4725-941e-0d3a7d7e631b"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>Warnings</title>
               <text>
                  <list listType="unordered">
                     <item>
                        <content styleCode="bold">Keep out of the reach of children under 6 years of age</content> .</item>
                     <item>If more than used for brushing is accidently swallowed ,get medical help or contact a Poison Control Center right away.</item>
                  </list>
               </text>
               <effectiveTime value="20201203"/>
            </section>
         </component>
         <component>
            <section ID="L93e96721-4ba0-4cf5-8e08-3f3bedd5421d">
