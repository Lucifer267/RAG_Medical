               <code codeSystem="2.16.840.1.113883.6.1" code="34069-5" displayName="HOW SUPPLIED SECTION"/>
               <title>HOW SUPPLIED:</title>
               <text>
                  <paragraph>Neomycin and Polymyxin B Sulfates and Dexamethasone Ophthalmic Suspension USP is supplied in a controlled drop tip bottle in the following size:</paragraph>
                  <paragraph>5 mL - Prod. No. 04107</paragraph>
                  <paragraph>
                     <content styleCode="underline">
                        <content styleCode="bold">DO NOT USE IF IMPRINTED NECKBAND IS NOT INTACT.</content>
                     </content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">FOR OPHTHALMIC USE ONLY</content>
                  </paragraph>
               </text>
               <effectiveTime value="20111007"/>
               <component>
                  <section ID="i4i_storage_id_6c7647ad-6694-4c43-9bc4-d6e51c85156a">
