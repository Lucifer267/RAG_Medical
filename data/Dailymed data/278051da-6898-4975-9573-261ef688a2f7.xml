            <section ID="ID_b36a28a7-1d4b-4c16-856c-b299a72dfb99">
               <id root="84dfcfaf-8daf-4d68-92a7-6c84a3bdf7eb"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Active ingredient:</content>Hydroquinone USP, 4% (40 mg/g)</paragraph>
                  <paragraph>
                     <content styleCode="bold">Inactive ingredients: </content>water, glycerin, cetyl alcohol, PPG-2 myristyl ether propionate, sodium lauryl sulfate, TEA-salicylate, lactic acid, phenyl trimethicone, tocopheryl acetate, sodium metabisulfite, ascorbic acid, methylparaben, disodium EDTA, propylparaben, saponins, BHT</paragraph>
