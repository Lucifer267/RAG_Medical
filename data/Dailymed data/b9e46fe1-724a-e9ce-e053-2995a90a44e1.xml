               <code code="43685-7" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS AND PRECAUTIONS SECTION"/>
               <title>
                  <content styleCode="bold">Warnings</content>
               </title>
               <text>
                  <paragraph>KEEP OUT OF REACH OF CHILDREN. For professional use only.</paragraph>
                  <paragraph/>
                  <paragraph>Not recommended for use by children under 6 years of age.</paragraph>
                  <paragraph/>
                  <paragraph>Do not swallow.</paragraph>
                  <paragraph/>
                  <paragraph>Store at room temperature. Do not expose to excessive heat over 40ºC or 104ºF.</paragraph>
                  <paragraph/>
                  <paragraph>Do not use if seal is broken.</paragraph>
               </text>
               <effectiveTime value="20171201"/>
            </section>
