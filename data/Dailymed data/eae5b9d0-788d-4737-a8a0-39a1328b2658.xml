            <section>
               <id root="27890519-5e81-4459-8a57-673e5ecca772"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">NOTE: This solution is hypertonic - See <content styleCode="italics">
                           <linkHtml href="#Warnings">WARNINGS</linkHtml>
                        </content> and <content styleCode="italics">
                           <linkHtml href="#Precautions">PRECAUTIONS</linkHtml>
                        </content>. 							</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">LifeShield<sup>®</sup> Abboject<sup>®</sup> Syringe Fliptop Container</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">Ansyr™ II Plastic Syringe</content>
                     <br/>Rx only 						</paragraph>
               </text>
               <effectiveTime value="20200521"/>
            </section>
