               <text>
                  <table width="75%" styleCode="Noautorules">
                     <col width="70%" align="left" valign="top"/>
                     <col width="30%" align="right" valign="top"/>
                     <tbody>
                        <tr>
                           <td colspan="2" align="left">Each caplet contains:</td>
                        </tr>
