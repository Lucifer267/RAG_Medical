            <section ID="Ld4113a54-b9ed-4d20-a0bb-b6690bcf7966">
               <id root="20990720-b01c-4add-9ca5-82548bbe3003"/>
               <code code="34089-3" codeSystem="2.16.840.1.113883.6.1" displayName="DESCRIPTION SECTION"/>
               <title>Description</title>
               <text>
                  <paragraph>NephPlex Rx is a prescription folic acid supplement with additional nutrients for kidney dialysis patients. NephPlex Rx is a white, film-coated, oval shaped tablet.</paragraph>
               </text>
               <effectiveTime value="20210713"/>
            </section>
