               <id root="707705f9-dc33-7c05-ca3e-3f3795e91a8e"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>
                  <content styleCode="bold">Warnings:</content> Keep out of reach of children. Do not use on people with known allergies to benzocaine.</title>
               <text/>
               <effectiveTime value="20150608"/>
            </section>
