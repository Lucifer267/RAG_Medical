            <section ID="ID_4E389CF0-82E7-080E-8A74-5266D8CCDDE9">
               <id root="2c4f23a8-b0c6-cb03-36a3-ac6f54729aac"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>
                  <content styleCode="bold"/>Directions for Use:<br/>1. Using the pull tab, peel open the lidding material first exposing the cotton tip applicator and then the individual reservoir of Benzo-Jel.<br/>2. Using the cotton tip applicator, apply Benzo-Jel to the desired mucosa.<br/>
               </title>
               <text/>
               <effectiveTime value="20150608"/>
            </section>
         </component>
