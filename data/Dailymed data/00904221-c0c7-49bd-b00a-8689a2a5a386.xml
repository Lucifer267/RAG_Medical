            <section>
               <id root="ffb3fdd9-417f-4f7c-ac23-5e9b75c3b6b7"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>WARNINGS</title>
               <text>
                  <paragraph>For topical ocular use only. Not for injection or oral use.</paragraph>
               </text>
               <effectiveTime value="20110105"/>
            </section>
