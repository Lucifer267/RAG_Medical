            <section ID="i4i_section_id_a711cac5-103e-45cd-92b6-ab5d58e5dca7">
               <id root="b230361e-de3a-4679-9583-5cbb1304f979"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Rx only</content>
                  </paragraph>
