            <section>
               <id root="7b25f16b-c382-48a6-99c8-10bb8bab5e06"/>
               <code code="42230-3" codeSystem="2.16.840.1.113883.6.1" displayName="SPL PATIENT PACKAGE INSERT SECTION"/>
               <text>
                  <content styleCode="bold">
                     <content styleCode="bold">
                        <content>NeutraCare</content>
                     </content>
                  </content>
                  <content>
                     <br/>
Home Topical Treatment (1.1% w/w Neutral Sodium Fluoride)<br/>
                     <br/>Active Ingredient: Sodium Fluoride 1.1% w/w (0.5% fluoride ion)<br/>
                  </content>
               </text>
               <effectiveTime value="20110303"/>
            </section>
