            <section ID="i4i_section_id_bbd2cb9e-1dcc-403a-8b86-d0cbf2a20c52">
               <id root="2d959f16-c52c-418c-b903-b72e25f861bf"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>Sterile</paragraph>
               </text>
               <effectiveTime value="20060530"/>
            </section>
