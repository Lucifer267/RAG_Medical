               <code codeSystem="2.16.840.1.113883.6.1" code="51945-4" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>Nystatin 500,000 units</title>
               <text>
                  <renderMultiMedia referencedObject="lbl681511487"/>
               </text>
               <effectiveTime value="20131015"/>
               <component>
                  <section ID="i4i_section_id_d0f60227-be77-4714-96d1-e54f2c9df20b">
                     <id root="369c45b9-9390-4dce-845a-bf6ca15f47eb"/>
                     <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
                     <title>Nystatin Tablets USP 500,000 units (Oral) 100 Label Text</title>
                     <text>
                        <paragraph>0093- -01
                                    <content styleCode="bold">NDC</content>
                           <content styleCode="bold">0983</content>
                        </paragraph>
