               <component>
                  <section>
                     <id root="c3635eab-8b63-484b-aacf-ae9326d125c6"/>
                     <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
                     <title>
                        <content styleCode="bold">Store and Dispense</content>
                     </title>
                     <text>
                        <paragraph>
                           <content styleCode="italics">Tablets</content>:  Store below 25°C (77°F); in tight, light-resistant container. </paragraph>
                        <paragraph>
                           <content styleCode="italics">Ampuls:</content>  Store in refrigerator, 2ºC-8°C (36°F-46°F). Protect from light. Administer only if solution is clear and colorless.</paragraph>
                     </text>
                     <effectiveTime value="20090618"/>
