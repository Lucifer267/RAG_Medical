            <section ID="i4i_storage_id_567d5d46-450f-496f-a806-8b0bfa5a534e">
               <id root="31fbb3b3-cc3f-4d24-b949-06b2616a5c41"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="44425-7" displayName="STORAGE AND HANDLING SECTION"/>
               <text>
                  <paragraph>Store between 2°- 25°C (36°- 77°F). Avoid exposure to excessive heat.
                            <content styleCode="bold">Storage:</content>
                  </paragraph>
                  <paragraph>KEEP OUT OF REACH OF CHILDREN.</paragraph>
