               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <title>PURPOSE:</title>
               <text>
                  <paragraph>RX STRENGTH TOPICAL RETINOID FOR TREATMENT OF ACNE, SHAVING BUMPS, AND SPECIFIC BUMPY SKIN PROBLEMS. LEAVES SKIN SMOOTH, CLEAR AND NEW.</paragraph>
                  <paragraph>uSES: ACNE AND SPECIFIC SKIN CONDITIONS.</paragraph>
               </text>
               <effectiveTime value="20150522"/>
            </section>
