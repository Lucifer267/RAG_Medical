               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>Ranitidine Hydrochloride Oral Suspension Pineapple/Orange Oral Suspension Kit Label</title>
               <text>
                  <paragraph/>
                  <paragraph/>
                  <paragraph>
                     <content styleCode="bold">NDC 70332-109-01</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">Rx only</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">Ranitidine Hydrochloride Oral Suspension and Pineapple/Orange Oral Suspension Kit</content>
                  </paragraph>
                  <paragraph>(ranitidine hydrochloride 25.0 mg/mL [equivalent to 22.4 mg/mL rantidine],</paragraph>
                  <paragraph>in a Pineapple/Orange oral suspension kit) Histamine-2 blocker</paragraph>
                  <paragraph/>
                  <paragraph>
                     <content styleCode="bold">Description:</content>
                  </paragraph>
