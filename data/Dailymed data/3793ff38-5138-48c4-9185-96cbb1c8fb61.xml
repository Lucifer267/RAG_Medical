               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <title>Use</title>
               <text>
                  <paragraph>This is a prescription fluoride treatment foam used to help prevent dental decay.</paragraph>
               </text>
               <effectiveTime value="20200303"/>
            </section>
