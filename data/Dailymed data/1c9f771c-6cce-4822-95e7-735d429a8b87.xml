         <component>
            <section>
               <id root="ffb891a3-3cd7-4bff-bcca-fcceb73dcc84"/>
               <code code="34089-3" codeSystem="2.16.840.1.113883.6.1" displayName="DESCRIPTION SECTION"/>
               <title>DESCRIPTION</title>
               <text>
                  <paragraph>Sulfacetamide Sodium Ophthalmic Solution 10% is a sterile topical 
antibacterial agents for ophthalmic use. The active ingredient is represented by 
the following structural formula:</paragraph>
                  <br/>
                  <paragraph>
                     <renderMultiMedia referencedObject="MM1"/>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">Chemical Name: </content>
                  </paragraph>
                  <paragraph>N-Sulfanilylacetamide monosodium salt monohydrate.</paragraph>
                  <paragraph>C<sub>8</sub>H<sub>9</sub>N<sub>2</sub>Na0<sub>3</sub>S·H<sub>2</sub>O</paragraph>
                  <paragraph>MW = 254.24</paragraph>
                  <paragraph>
                     <content styleCode="bold">Contains:</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">Active: </content>sulfacetamide sodium 10% (100 mg/mL).</paragraph>
                  <paragraph>
                     <content styleCode="bold">Preservative: </content>methylparaben and propylparaben</paragraph>
                  <paragraph>
                     <content styleCode="bold">Inactives: </content>sodium thiosulfate, methylcellulose, and 
monobasic sodium phosphate</paragraph>
               </text>
               <effectiveTime value="20110627"/>
               <component>
                  <observationMedia classCode="OBS" moodCode="EVN" ID="MM1">
                     <text>Structure Image</text>
                     <value xsi:type="ED" mediaType="image/jpeg">
                        <reference value="SULFA OPHTH SOL STRUCT.jpg"/>
                     </value>
                  </observationMedia>
               </component>
