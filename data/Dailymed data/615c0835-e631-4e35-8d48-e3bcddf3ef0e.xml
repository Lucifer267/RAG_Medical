            <section ID="L5c827dd1-79e9-4f76-b7f8-10990a06f46c">
               <id root="2f517f14-687a-46fc-9619-1972bda1623d"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>DIRECTIONS:</title>
               <text>
                  <paragraph>APPLY IN A VERY THIN LAYER IN THE DARK AREA ONLY. FOR DARK SPOTS APPLY TO THE CENTER OF DARK SPOTS.</paragraph>
                  <paragraph>FREQUENCY OF APPLICATION: DETERMINED BY DR. THROWER.</paragraph>
                  <paragraph/>
               </text>
               <effectiveTime value="20150522"/>
            </section>
