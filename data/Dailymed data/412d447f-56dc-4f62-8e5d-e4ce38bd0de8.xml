         <component>
            <section ID="Ld13fc6fe-ae9a-4049-bd84-23f3f6f8a772">
               <id root="213ea8be-1a58-403d-a63e-fbd44bc754b2"/>
               <code code="55105-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - PURPOSE SECTION"/>
               <title>Purpose</title>
               <text>
                  <paragraph> Pain relief cream to assist with relief of joint and muscle pain.</paragraph>
               </text>
               <effectiveTime value="20150216"/>
            </section>
         </component>
         <component>
            <section ID="L2bc27bfe-58dc-428d-b100-e242b45bd1a0">
               <id root="361750b2-c8bb-4e0e-b7e2-e2d8a4f1d488"/>
               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <title>Indication and Usage</title>
               <text>
                  <paragraph>For the temporary relief of arthritic pain &amp; relief of muscular aches &amp; pains, including symptomatic relief of lower back pains. May</paragraph>
                  <paragraph>also assist with increased joint mobility &amp; reduce inflammation and swelling associated with arthritis and gout.</paragraph>
                  <paragraph/>
               </text>
               <effectiveTime value="20150216"/>
            </section>
         </component>
         <component>
            <section ID="L63a1de79-acec-402c-802a-0bce645e7c1a">
               <id root="cb5f4968-20cf-4607-8064-77ec06003faa"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>Dosage and Administration</title>
               <text>
                  <paragraph>Apply a small amount of  Original Pain Relief Cream to the affected area &amp; gently massage in until fully absorbed. Use</paragraph>
                  <paragraph>twice daily or more frequently if required.</paragraph>
                  <paragraph/>
               </text>
               <effectiveTime value="20150216"/>
            </section>
         </component>
         <component>
            <section ID="Lac706552-852a-4056-8e81-0d882ecd00ee">
               <id root="dc658442-5e76-4252-b9f4-46851cf9dbfd"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>Warnings</title>
               <text>
                  <paragraph>For external use only.</paragraph>
                  <paragraph>Ensure safety seal is intact beforeopening. Keep tube sealed when not being used. Store below 30<sup>0</sup> C (86 F).</paragraph>
                  <paragraph>If symptoms persist seek the advice of a health care practioner.</paragraph>
                  <paragraph>Keep out of reach from children.</paragraph>
                  <paragraph/>
               </text>
               <effectiveTime value="20150216"/>
            </section>
         </component>
