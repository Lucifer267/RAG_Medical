            <section>
               <id root="dfd34b9c-e59f-4c85-96db-b77eb1927596"/>
               <code code="34089-3" codeSystem="2.16.840.1.113883.6.1" displayName="DESCRIPTION SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Each film-coated tablet contains</content>:</paragraph>
                  <paragraph>Cyclobenzaprine Hydrichloride, USP 10 mg<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20151016"/>
            </section>
