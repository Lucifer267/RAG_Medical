            <section ID="s1">
               <id root="0ab63cd8-4b26-461a-b625-4c4e5e04b8e5"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>easy interproximal therapy
</paragraph>
                  <paragraph>
                     <content styleCode="bold">INSTRUCTIONS FOR USE</content>
                  </paragraph>
               </text>
               <effectiveTime value="20160823"/>
            </section>
