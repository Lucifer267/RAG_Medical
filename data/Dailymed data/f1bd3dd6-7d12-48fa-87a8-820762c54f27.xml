                           <td align="right" valign="top">100 mg</td>
                        </tr>
                        <tr ID="id_ca1e0164-3f94-4e5a-a285-05aa61e3b4c0">
                           <td align="left" valign="top">Benzyl benzoate</td>
                           <td align="right" valign="top">0.1 mL</td>
                        </tr>
                        <tr ID="id_61a05b18-9206-4864-be20-65c6fc14e89c">
                           <td align="left" valign="top">Cottonseed oil</td>
                           <td align="right" valign="top">736 mg</td>
                        </tr>
                        <tr ID="id_50c8aa0b-c2aa-4e16-97a1-3630588b3fac" styleCode="Botrule">
