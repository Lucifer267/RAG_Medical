               </text>
               <effectiveTime value="20190222"/>
            </section>
         </component>
         <component>
            <section>
               <id root="010c5464-0fa8-46b9-8ff7-da9974667ce3"/>
               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>PRINCIPAL DISPLAY PANEL - 0.125 mg Tablet Bottle Label</title>
               <text>
                  <paragraph>
                     <content styleCode="bold">NDC 71186-009-25</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">HYOSCYAMINE SULFATE</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">Sublingual Tablets<br/>0.125 mg</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">EACH TABLET CONTAINS:</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">Hyoscyamine sulfate<br/>0.125 mg</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">RX ONLY</content>
