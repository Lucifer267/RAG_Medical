               </text>
               <effectiveTime value="20100610"/>
               <excerpt>
                  <highlight>
                     <text>
                        <paragraph>7.5 mL size bottle filled with 5 mL of besifloxacin ophthalmic suspension, 0.6% (<linkHtml href="#i4i_dosage_form_strength_id_f87d6e91-955f-4cc5-91a7-bc1f3ccebf29">3</linkHtml>)</paragraph>
                     </text>
                  </highlight>
               </excerpt>
            </section>
