               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <text>
                  <paragraph>Uses</paragraph>
                  <paragraph>- Scar Management    - Temporarily protects minor cuts , scrapes and burns</paragraph>
                  <paragraph>- Temporary relief of pain associated with minor cuts, scrapes and minor skin irritations
  <br/>
                  </paragraph>
               </text>
               <effectiveTime value="20150415"/>
            </section>
