                  <paragraph>
                     <content styleCode="bold">Lupin Limited</content>
                  </paragraph>
                  <paragraph>Pithampur (M.P.) 454 775, INDIA</paragraph>
                  <paragraph>Revised: January 2018</paragraph>
                  <paragraph>ID#: 254190</paragraph>
               </text>
               <effectiveTime value="20180810"/>
            </section>
         </component>
