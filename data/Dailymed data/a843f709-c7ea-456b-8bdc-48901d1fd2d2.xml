               <code code="34070-3" codeSystem="2.16.840.1.113883.6.1" displayName="CONTRAINDICATIONS SECTION"/>
               <title>CONTRAINDICATIONS</title>
               <text>
                  <paragraph>Do not use in areas where drinking water exceeds 0.6 ppm F. Do not administer to pediatric patients less than 6 months old.</paragraph>
               </text>
               <effectiveTime value="20170419"/>
            </section>
