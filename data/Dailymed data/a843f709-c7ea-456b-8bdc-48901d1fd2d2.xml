               <component>
                  <section>
                     <id root="1ba3a633-0065-4eb5-802d-03dcb73dc238"/>
                     <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
                     <title>STORAGE</title>
                     <text>
                        <paragraph>Store in a cool, dry place at room temperature 20°C to 25°C (68°F to 77°F) away from heat and sunlight.</paragraph>
                        <paragraph>
                           <content styleCode="bold">SHAKE WELL BEFORE USING</content>
                        </paragraph>
                     </text>
                     <effectiveTime value="20170419"/>
                  </section>
               </component>
            </section>
