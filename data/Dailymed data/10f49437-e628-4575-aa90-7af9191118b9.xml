         <component>
            <section ID="L2a6df292-3ac7-44a9-a1a6-9520154a9981">
               <id root="f4182591-d821-442c-ae5c-e1cedeb996ec"/>
               <code code="34069-5" codeSystem="2.16.840.1.113883.6.1" displayName="HOW SUPPLIED SECTION"/>
               <title>• HOW SUPPLIED</title>
               <text>
                  <paragraph>Contains 25,000 USP Units of Heparin Sodium in 0.45% Sodium Chloride in a 250 mL Single-Dose Bag.  Volume &amp; Concentration exlude additive &amp; manufacturer overfill.</paragraph>
                  <paragraph>This product is Sterile, Nonpyrogenic, and Latex Free.</paragraph>
               </text>
               <effectiveTime value="20150515"/>
            </section>
         </component>
         <component>
            <section ID="La82261f3-d54a-4c65-9b69-ef15c52c2bd8">
               <id root="a6823baa-7e6a-4c6e-9941-01ac31eca78d"/>
               <code code="43678-2" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE FORMS &amp; STRENGTHS SECTION"/>
               <title>• INGREDIENTS</title>
               <text>
                  <paragraph>Each 1 mL contains contains Heparin Sodium 100 USP Units, Sodium Chloride 4.5 mg, Benzyl Alcohol 0.0002 mL. May contain Hydrochloric Acid and/or Sodium Hydroxide for pH adjustment.</paragraph>
               </text>
               <effectiveTime value="20150515"/>
            </section>
         </component>
         <component>
