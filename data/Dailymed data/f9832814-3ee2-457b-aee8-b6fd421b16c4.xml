               <component>
                  <section>
                     <id root="72d546c9-2d12-4c5e-9cb3-31f84e7da455"/>
                     <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
                     <text>
                        <paragraph>Uses: <br/>
                        </paragraph>
                        <paragraph>-For the treatment of acne</paragraph>
                        <paragraph>-Helps prevent new acne blemishes</paragraph>
                        <br/>
                        <paragraph>Directions</paragraph>
                        <paragraph>-Cleanse skin thoroughly before applying</paragraph>
                        <paragraph>-Apply to cotton pad and wipe over skin, avoiding eye area.</paragraph>
                        <paragraph>
                           <br/>
                        </paragraph>
                     </text>
                  </section>
               </component>
               <component>
                  <section>
                     <id root="e4a4443b-bcd5-433c-9325-903ca5cc0905"/>
                     <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
                     <text>
                        <paragraph>Warnings</paragraph>
                        <paragraph>-For external use only</paragraph>
                        <paragraph>-When using this product: Using other topical acne medication at the same time or immediately following the use of this product may increase dryness or irritation of the skin. If this occurs, only one medication should be used unless directed by a doctor. If sensitive to the sun or when increased sun exposure is expected use a sunscreen when using this and other acne products. <br/>
                        </paragraph>
                        <paragraph>-Keep out of reach of children. If swallowed, get medical help or contact poison center right away. <br/>
                        </paragraph>
                     </text>
                  </section>
               </component>
