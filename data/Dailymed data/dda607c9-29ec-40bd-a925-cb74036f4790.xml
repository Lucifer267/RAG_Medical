         <component>
            <section ID="s1">
               <id root="88372a3f-fefa-4975-bd47-5145fde8567a"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Rx only</content>
                  </paragraph>
                  <paragraph>NOT FOR OPHTHALMIC USE.</paragraph>
                  <paragraph>FOR DERMATOLOGIC USE ONLY.</paragraph>
               </text>
               <effectiveTime value="20140403"/>
            </section>
