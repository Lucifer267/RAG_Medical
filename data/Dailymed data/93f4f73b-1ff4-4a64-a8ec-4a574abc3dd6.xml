                  <paragraph>Rising Pharma Holdings, Inc.</paragraph>
                  <paragraph>East Brunswick, NJ 08816</paragraph>
                  <paragraph>Rev. 08/2021</paragraph>
               </text>
               <effectiveTime value="20220208"/>
            </section>
         </component>
