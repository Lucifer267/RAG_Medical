               <title>HOW SUPPLIED</title>
               <text>
                  <paragraph>Calcipotriene Ointment, 0.005% is available in:</paragraph>
                  <paragraph>60 gram aluminum tubes <content styleCode="bold">NDC</content> 66993-878-61</paragraph>
                  <paragraph>120 gram aluminum tubes <content styleCode="bold">NDC</content> 66993-878-78</paragraph>
               </text>
               <effectiveTime value="20200807"/>
            </section>
         </component>
         <component>
            <section ID="L2007a7b3-8d97-49ad-84f8-c236505c6494">
               <id root="8ed82246-2205-4399-9aa8-43835fab817f"/>
               <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
               <title>STORAGE</title>
               <text>
                  <paragraph>Store at controlled room temperature 15°C-25°C (59°F-77°F). Do not freeze.</paragraph>
               </text>
               <effectiveTime value="20200807"/>
            </section>
         </component>
