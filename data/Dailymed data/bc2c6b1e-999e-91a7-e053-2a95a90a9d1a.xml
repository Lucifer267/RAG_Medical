               <id root="bc2c8919-4767-27f4-e053-2a95a90aaf8e"/>
               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <text>
                  <paragraph>Naproxen Tablets are indicated for:
  <br/>
                     <br/>
the relief of the signs and symptoms of:
 </paragraph>
                  <paragraph>rheumatoid arthritis
  <br/>
osteoarthritis
  <br/>
ankylosing spondylitis
  <br/>
polyarticular juvenile idiopathic arthritis
  <br/>
tendonitis
  <br/>
bursitis
  <br/>
acute gout
 </paragraph>
                  <paragraph/>
                  <paragraph>the management of:</paragraph>
                  <paragraph>pain
  <br/>
primary dysmenorrhea
 </paragraph>
               </text>
               <effectiveTime value="20200301"/>
            </section>
