               <id root="5dedd7f2-e2e4-4d7a-8991-464336be02e9"/>
               <code code="34089-3" codeSystem="2.16.840.1.113883.6.1" displayName="DESCRIPTION SECTION"/>
               <text>
                  <paragraph>Usual Dosage:  For dosage and other prescribing</paragraph>
                  <paragraph>information, see accompanying insert.<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20151015"/>
