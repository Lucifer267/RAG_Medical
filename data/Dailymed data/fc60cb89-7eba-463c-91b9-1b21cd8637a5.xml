            <section ID="s1">
               <id root="2ecf019b-4b1a-42ad-a360-8223b171f112"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph/>
                  <paragraph>
                     <content styleCode="bold">Rx only</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">For topical use only. Not for ophthalmic use.</content>
                  </paragraph>
               </text>
