            <section ID="s1">
               <id root="d03dd44e-2873-4921-ac5e-e3e4698fd4b4"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>Ophthalmic Solution, USP<br/>0.5% Sterile
</paragraph>
                  <paragraph>Rx Only
</paragraph>
               </text>
               <effectiveTime value="20150327"/>
            </section>
