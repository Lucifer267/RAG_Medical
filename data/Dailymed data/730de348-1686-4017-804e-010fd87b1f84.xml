               <code code="34069-5" codeSystem="2.16.840.1.113883.6.1" displayName="HOW SUPPLIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">PACKAGE</content>
                  </paragraph>
                  <paragraph>10 Blister Packs with 10 Tablets in each Blister Pack<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20110518"/>
            </section>
