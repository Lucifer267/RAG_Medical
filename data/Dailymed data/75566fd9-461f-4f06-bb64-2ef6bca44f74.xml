               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>Do not use on people with known allergies to benzocaine and PABA compounds.</paragraph>
               </text>
               <effectiveTime value="20100827"/>
            </section>
