         <component>
            <section ID="P1">
               <id root="c27ca699-453e-4a36-9dcd-759e88b24c29"/>
               <code code="55106-9" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - ACTIVE INGREDIENT SECTION"/>
               <title>INGREDIENTS</title>
               <text>
                  <paragraph>Each gram of Benzo-Jel™ 20% benzocaine gel contains between 180-220 mg benzocaine USP, in a water soluble base of PEG 3350 USP, PEG 400 USP, flavor, Sodium Saccharin USP, FD&amp;C Red #28, FD&amp;C Red #40 and FD&amp;C Blue #1.</paragraph>
               </text>
               <effectiveTime value="20100827"/>
            </section>
         </component>
         <component>
            <section ID="P12">
               <id root="462189ce-02a7-440f-811c-62a65b6d4c3c"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>USUAL DOSAGE</title>
               <text>
                  <paragraph>For oral mucosal use only as directed by a dentist.</paragraph>
               </text>
               <effectiveTime value="20100827"/>
            </section>
         </component>
