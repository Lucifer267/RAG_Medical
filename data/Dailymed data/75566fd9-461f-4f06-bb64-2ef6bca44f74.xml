               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>WARNING</title>
               <text>
                  <paragraph>Keep out of the reach of children. </paragraph>
               </text>
               <effectiveTime value="20100827"/>
            </section>
         </component>
         <component>
            <section ID="P13">
               <id root="209b1bf9-b0c2-460e-9402-e634f28c176d"/>
               <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
               <text>
                  <paragraph>Store at controlled room temperature 59°-86°F (15°-30°C).</paragraph>
               </text>
               <effectiveTime value="20100827"/>
            </section>
         </component>
         <component>
            <section ID="P18">
