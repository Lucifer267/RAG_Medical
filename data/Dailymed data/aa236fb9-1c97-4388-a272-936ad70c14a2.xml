         <component>
            <section>
               <id root="67e27135-4d13-4cb7-a925-8da3e19cf9e1"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>WARNING</title>
               <text>
                  <paragraph>
                     <content styleCode="bold">KEEP THIS AND ALL MEDICATIONS OUT OF THE REACH OF CHILDREN. IF OVERDOSAGE IS SUSPECTED, SEEK PROFESSIONAL ASSISTANCE OR CONTACT A POISON CONTROL CENTER IMMEDIATELY 1-800-222-1222. TABLET SHOULD BE CHEWED. THIS PRODUCT, AS WITH ALL CHEWABLE TABLETS, IS NOT RECOMMENDED FOR CHILDREN UNDER AGE 4 DUE TO RISK OF CHOKING.</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">DO NOT USE IF FOIL SEAL UNDER CAP IS BROKEN OR MISSING</content>
                  </paragraph>
               </text>
               <effectiveTime value="20170601"/>
            </section>
         </component>
