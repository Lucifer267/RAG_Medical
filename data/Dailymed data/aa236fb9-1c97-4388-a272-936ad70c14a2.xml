            <section>
               <id root="e7c6d80a-35a9-460b-a11b-e5fe3335035a"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <title/>
               <text>
                  <table width="60%">
                     <col align="left" valign="top" width="75%"/>
                     <col align="right" valign="top" width="25%"/>
                     <thead>
                        <tr styleCode="Toprule">
                           <th align="left" colspan="2">Each Multivitamin with 1.0 mg Fluoride Tablet Contains:</th>
                        </tr>
                     </thead>
                     <tbody>
                        <tr styleCode="Toprule">
                           <td>Vitamin A (as Acetate)</td>
                           <td>2500 IU</td>
                        </tr>
                        <tr>
                           <td>Vitamin C</td>
                           <td>60 mg</td>
                        </tr>
                        <tr>
                           <td>Vitamin D</td>
                           <td>400 IU</td>
                        </tr>
                        <tr>
                           <td>Vitamin E</td>
                           <td>15 IU</td>
                        </tr>
                        <tr>
                           <td>Thiamine</td>
                           <td>1.05 mg</td>
                        </tr>
                        <tr>
                           <td>Riboflavin</td>
                           <td>1.2 mg</td>
                        </tr>
                        <tr>
                           <td>Niacin</td>
                           <td>13.5 mg</td>
                        </tr>
                        <tr>
                           <td>Vitamin B6</td>
                           <td>1.05 mg</td>
                        </tr>
                        <tr>
                           <td>Folate (as Folic Acid)</td>
                           <td>0.3 mg</td>
                        </tr>
                        <tr>
                           <td>Vitamin B12</td>
                           <td>4.5 mcg</td>
                        </tr>
                        <tr styleCode="Botrule">
                           <td>Fluoride (as Sodium Fluoride)<footnote>
                                 <content styleCode="bold">Each Multivitamin with 1.0 mg Fluoride Tablet contains 1.0 mg Fluoride from 2.2 mg Sodium Fluoride (NaF).</content>
                              </footnote>
                           </td>
                           <td>1.0 mg</td>
                        </tr>
                     </tbody>
                  </table>
               </text>
               <effectiveTime value="20170601"/>
            </section>
