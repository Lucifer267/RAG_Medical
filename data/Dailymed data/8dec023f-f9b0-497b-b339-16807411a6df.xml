               </text>
               <effectiveTime value="20200326"/>
               <component>
                  <section>
                     <id root="c041cbe9-5ccb-402c-a64d-dc95cf22f097"/>
                     <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
                     <text>
                        <paragraph>Store at 20° to 25°C (68° to 77°F) [See USP Controlled Room Temperature].</paragraph>
                        <paragraph>Dispense contents with a child-resistant closure (as required) and in a tight container as defined in the USP/NF.</paragraph>
                     </text>
                     <effectiveTime value="20200326"/>
                  </section>
               </component>
            </section>
         </component>
         <component>
            <section>
