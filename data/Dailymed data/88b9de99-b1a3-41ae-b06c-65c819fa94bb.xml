               <title>Other information</title>
               <text>
                  <paragraph>Store at a room temperature. </paragraph>
                  <paragraph/>
                  <list listType="unordered" ID="i43824d02-fc44-4c8c-8344-66406e1059bf">
                     <item>Keep lid tightly closed in a dry place</item>
                     <item>Do not use if imprinted safety seal under cap is broken or missing</item>
                     <item>keep out of reach of children<br/>
                     </item>
                  </list>
               </text>
               <effectiveTime value="20130709"/>
            </section>
