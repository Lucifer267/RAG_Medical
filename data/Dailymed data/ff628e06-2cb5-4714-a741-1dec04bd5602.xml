                        <paragraph>GBT 0862A0817<br/>Revised 08/17      </paragraph>
                        <paragraph>
                           <content styleCode="bold">Guerbet</content>
                        </paragraph>
                     </text>
                     <effectiveTime value="20150831"/>
                  </section>
