            <section ID="LINK_3bb5b96c-8536-4b61-be7d-7b9329e15147">
               <id root="17e71e67-899f-45e3-a605-17a9a4394d4a"/>
               <code code="34066-1" codeSystem="2.16.840.1.113883.6.1" displayName="BOXED WARNING SECTION"/>
