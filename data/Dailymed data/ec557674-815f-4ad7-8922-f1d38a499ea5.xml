            <section ID="i4i_storage_id_bd3cf533-0c1b-47b2-8999-df10bc2507fa">
               <id root="b06e94bd-b01a-46e1-93d2-dd9072c3c5a6"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="44425-7" displayName="STORAGE AND HANDLING SECTION"/>
               <title>STORAGE</title>
               <text>
                  <paragraph>Store at controlled room temperature 15° C - 25° C (59° F - 77° F). Do not freeze.</paragraph>
               </text>
               <effectiveTime value="20091125"/>
            </section>
