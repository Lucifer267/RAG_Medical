               <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
               <title>STORAGE</title>
               <text>
                  <paragraph>Store at 20-25°C (68-77°F) [see USP Controlled Room Temperature]. Protect from light.</paragraph>
               </text>
               <effectiveTime value="20130107"/>
            </section>
         </component>
