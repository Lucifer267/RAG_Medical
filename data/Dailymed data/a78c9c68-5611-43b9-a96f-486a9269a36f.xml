               <text>
                  <paragraph>Rx Only</paragraph>
                  <paragraph>Manufactured for:<br/>Vilvet Pharmaceuticals Inc<br/>Chester Springs, PA 19425<br/>Rev /2011</paragraph>
               </text>
               <effectiveTime value="20190221"/>
            </section>
         </component>
