               <code codeSystem="2.16.840.1.113883.6.1" code="34069-5" displayName="HOW SUPPLIED SECTION"/>
               <title>How Supplied</title>
               <text>
                  <paragraph>Erythromycin Ophthalmic Ointment USP, 0.5% is available in the following sizes:</paragraph>
                  <paragraph>1/8 oz. (3.5 g) tamper-resistant tube – 09234</paragraph>
                  <paragraph>
                     <content styleCode="bold">DO NOT USE IF CAP AND NECKRING ARE NOT INTACT.</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">DO NOT USE IF BOTTOM RIDGE OF TUBE CAP IS EXPOSED.</content>
                  </paragraph>
               </text>
               <effectiveTime value="20081009"/>
            </section>
         </component>
         <component>
            <section ID="i4i_storage_id_ebf2eb65-9225-4d03-99ba-95d35e9b0dda">
               <id root="058380c1-7070-4709-a41a-5cb4225807c2"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="44425-7" displayName="STORAGE AND HANDLING SECTION"/>
               <title>Storage</title>
               <text>
                  <paragraph>Store between 15°-30°C (59°-86°F).</paragraph>
                  <paragraph>KEEP OUT OF REACH OF CHILDREN.</paragraph>
                  <paragraph>Revised February 2007</paragraph>
                  <paragraph>Rx only</paragraph>
               </text>
               <effectiveTime value="20081009"/>
            </section>
