               <title>HOW SUPPLIED</title>
               <text>
                  <paragraph>NDC:68151-2193-0 in a PACKAGE  of 1 TABLET, SOLUBLES</paragraph>
               </text>
               <effectiveTime value="20160617"/>
               <component>
                  <section>
                     <id root="c094efc2-0213-4f0d-9ff9-cfd2c97a9c33"/>
                     <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
                     <title>STORAGE</title>
                     <text>
                        <paragraph>
                           <content styleCode="italics">Keep tightly closed. Store at controlled room temperature, 20°-25°C (68°-77°F).</content>
                        </paragraph>
                        <paragraph>
                           <content styleCode="italics">Dispense in tight, light-resistant containers with child-resistant closures.</content>
                        </paragraph>
                     </text>
                     <effectiveTime value="20140929"/>
                  </section>
               </component>
            </section>
         </component>
