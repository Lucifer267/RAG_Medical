                     <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
                     <text>
                        <paragraph>Warnings</paragraph>
                        <paragraph>-for external use only</paragraph>
                        <paragraph>-when using this product keep out of eyes</paragraph>
                        <paragraph>-rinse with water to remove</paragraph>
                        <paragraph>-stop use and ask a doctor if rash or irritation develops and lasts</paragraph>
                        <paragraph>-keep out of reach of children</paragraph>
                        <paragraph>-do not use on infants under 6 months of age<br/>
                        </paragraph>
                     </text>
                  </section>
