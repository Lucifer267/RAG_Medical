               <id root="1f967766-a957-459a-b59e-72b7ef41336a"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
               <title/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Folic Acid Tablets, USP</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">Rx Only</content>
                  </paragraph>
               </text>
               <effectiveTime value="20161227"/>
            </section>
