               <title>CAUTION:</title>
               <text>
                  <paragraph>Keep out of reach of children.</paragraph>
                  <paragraph/>
                  <paragraph>FOR PROFESSIONAL USE ONLY.</paragraph>
               </text>
               <effectiveTime value="20181120"/>
            </section>
