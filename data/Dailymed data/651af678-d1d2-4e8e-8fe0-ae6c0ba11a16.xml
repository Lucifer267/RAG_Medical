                     <id root="aaa83c88-dec7-4e27-b91b-25df501c2dc0"/>
                     <title>
                        <content styleCode="bold">Storage and Handling
</content>
                     </title>
                     <text>
                        <paragraph>Store the product at room temperature</paragraph>
                     </text>
                     <effectiveTime value="20120703"/>
                  </section>
               </component>
            </section>
