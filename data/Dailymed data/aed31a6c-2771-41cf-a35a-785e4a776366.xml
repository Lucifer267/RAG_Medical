               <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
               <text>
                  <list listType="unordered">
                     <item>Store at 59<sup>o</sup> - 86<sup>o</sup>F (15<sup>o</sup> - 30<sup>o</sup>C)</item>
                     <item>Protect from freezing</item>
                     <item>Ionite APF Gel is free of gluten, soymilk, egg peanut and free of nut products</item>
                  </list>
               </text>
               <effectiveTime value="20130101"/>
            </section>
