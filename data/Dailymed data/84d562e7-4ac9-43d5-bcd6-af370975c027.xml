               <title>HOW SUPPLIED</title>
               <text>
                  <paragraph>White, round, biconvex compressed tablets debossed with "N" on one side and "01" on the other side. Available in bottles of 28 and 100 tablets.</paragraph>
               </text>
               <effectiveTime value="20110524"/>
