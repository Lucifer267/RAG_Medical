               <code codeSystem="2.16.840.1.113883.6.1" code="51945-4" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>PRINCIPAL DISPLAY PANEL - CARTON LABEL 3.5 g (1/8 Oz)</title>
               <text>
                  <renderMultiMedia referencedObject="id_b083d4f0-cb59-4457-8406-3d0c62d602a1"/>
                  <paragraph>
                     <content styleCode="bold">Rx only</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">ERYTHROMYCIN<br/>OPHTHALMIC OINTMENT USP<br/>
                     </content>STERILE</paragraph>
                  <paragraph>
                     <content styleCode="bold">USUAL DOSAGE:</content> Apply to the affected area one or more times daily.<br/>See insert for complete information.</paragraph>
                  <paragraph>
                     <content styleCode="bold">CONTAINS: </content>Erythromycin USP 5 mg per gram in a sterile ophthalmic base of Mineral Oil and White Petrolatum.</paragraph>
                  <paragraph>
                     <content styleCode="bold">NET WT 3.5 g (1/8 Oz)</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">STORE AT ROOM TEMPERATURE.<br/>AVOID EXCESSIVE HEAT.<br/>PROTECT FROM FREEZING.<br/>KEEP TIGHTLY CLOSED.</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">WARNING: Keep out of reach of children.</content>
                  </paragraph>
               </text>
               <effectiveTime value="20100729"/>
