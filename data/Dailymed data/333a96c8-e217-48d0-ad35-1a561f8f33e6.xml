         <component>
            <section ID="L3864a54f-f496-4f22-a52b-40afafe41072">
               <id root="efa67b74-4a82-4993-ac54-ee43cd0be0d4"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>Suggested Dosage</title>
               <text>
                  <paragraph>1-3 tablets with each meal as directed by the physician.</paragraph>
               </text>
               <effectiveTime value="20140609"/>
            </section>
         </component>
         <component>
            <section ID="L6a9b8562-77a4-4392-bc9a-1b2853f09867">
               <id root="3672e8af-554b-40a3-93da-c47f3e19019f"/>
               <code code="34070-3" codeSystem="2.16.840.1.113883.6.1" displayName="CONTRAINDICATIONS SECTION"/>
               <title>Contraindications</title>
               <text>
                  <paragraph>Patients who are hypermagnesemic or who have impaired renal function and are not being dialyzed should not be prescribed MagneBind 400 Rx.</paragraph>
               </text>
               <effectiveTime value="20140609"/>
            </section>
