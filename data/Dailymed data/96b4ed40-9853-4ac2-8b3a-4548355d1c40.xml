                     <code codeSystem="2.16.840.1.113883.6.1" code="44425-7" displayName="STORAGE AND HANDLING SECTION"/>
                     <title>Storage:</title>
                     <text>
                        <paragraph>Store between 15° – 30° C (59°– 86° F).</paragraph>
                        <paragraph>
                           <content styleCode="bold">
                              <content styleCode="emphasis">PROTECT FROM LIGHT.</content>
                           </content>
                        </paragraph>
                        <paragraph>KEEP OUT OF REACH OF CHILDREN.</paragraph>
                        <paragraph>Revised August 2007</paragraph>
                     </text>
                     <effectiveTime value="20110228"/>
                  </section>
               </component>
