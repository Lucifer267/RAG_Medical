               <title>USES</title>
               <text>
                  <paragraph>ECZEMA, SPECIFIC DRY SKIN, AND SPECIFIC SKIN IRRITATIONS.</paragraph>
                  <paragraph/>
               </text>
               <effectiveTime value="20150515"/>
            </section>
