         </component>
         <component>
            <section ID="Lce2c3dda-7c64-4f4b-b0b9-d665073e2564">
               <id root="117035aa-d84a-46b4-a421-c747d4a8a763"/>
               <code code="34089-3" codeSystem="2.16.840.1.113883.6.1" displayName="DESCRIPTION SECTION"/>
               <title>DESCRIPTION</title>
               <text>
                  <paragraph>Ionite H Neutral Fluoride Gel is a flavored, pH neutral 1.1% sodium fluoride, 5% potassium nitrate gel that aids in the prevention of dental decay and hleps to treat sensitive teeth.</paragraph>
               </text>
               <effectiveTime value="20150802"/>
            </section>
         </component>
