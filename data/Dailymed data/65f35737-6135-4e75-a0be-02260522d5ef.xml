               <code code="34066-1" codeSystem="2.16.840.1.113883.6.1" displayName="BOXED WARNING SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">WARNING</content>
                  </paragraph>
                  <paragraph>Accidental overdose of <content styleCode="bold">iron-containing</content> products is a leading cause of fatal poisoning in children under 6. KEEP THIS PRODUCT OUT OF THE REACH OF CHILDREN. In case of accidental overdose, call a doctor or poison control center immediately.</paragraph>
               </text>
               <effectiveTime value="20200918"/>
            </section>
         </component>
         <component>
            <section>
               <id root="11b2836a-c2df-45d0-9d53-a8bce1e626fc"/>
               <code code="69718-5" codeSystem="2.16.840.1.113883.6.1" displayName="STATEMENT OF IDENTITY SECTION"/>
               <text>
                  <paragraph>Each prenatal tablet contains:</paragraph>
                  <paragraph/>
                  <table width="0px" cellspacing="0" cellpadding="0">
                     <tbody>
                        <tr>
                           <td colspan="3" valign="top">
                              <paragraph>Each Tablet contains:</paragraph>
                           </td>
                        </tr>
                        <tr>
                           <td valign="top">
                              <paragraph>Vitamin A (as acetate, beta carotene)</paragraph>
                           </td>
                           <td valign="top"/>
                           <td valign="top">
                              <paragraph>1200 mcg</paragraph>
                           </td>
                        </tr>
                        <tr>
                           <td valign="top">
                              <paragraph>Vitamin D3 (as cholecalciferol)</paragraph>
                           </td>
                           <td valign="top"/>
                           <td valign="top">
                              <paragraph>10 mcg</paragraph>
                           </td>
                        </tr>
                        <tr>
                           <td valign="top">
                              <paragraph>Vitamin E (as dl-alpha topcopheryl acetate )</paragraph>
                           </td>
                           <td valign="top">
                              <paragraph/>
                           </td>
                           <td valign="top">
                              <paragraph>9.2 mg</paragraph>
                           </td>
                        </tr>
                        <tr>
                           <td valign="top">
                              <paragraph>Vitamin C (Ascorbic acid )</paragraph>
                           </td>
                           <td valign="top"/>
                           <td valign="top">
                              <paragraph>20 mg </paragraph>
                           </td>
                        </tr>
                        <tr>
                           <td valign="top">
                              <paragraph>Vitamin B1 (as thiamine HCl)</paragraph>
                           </td>
                           <td valign="top"/>
                           <td valign="top">
                              <paragraph>1.84 mg</paragraph>
                           </td>
                        </tr>
                        <tr>
