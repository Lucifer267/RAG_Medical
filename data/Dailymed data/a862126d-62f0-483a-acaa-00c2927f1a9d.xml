               <text>
                  <br/>
                  <paragraph>
                     <br/>
                  </paragraph>
                  <paragraph>Tray/Case Label <br/>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">TERUFLEX® BLOOD BAG SYSTEM with <br/>BLOOD SAMPLING ARM®<br/>
                        <br/>
                     </content>
                     <br/>
                     <content styleCode="bold">CPD WITH OPTISOL® RED CELL PRESERVATIVE SOLUTION<br/>FOR COLLECTION OF 500mL OF BLOOD</content>
