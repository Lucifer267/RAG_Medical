            <section ID="i4i_section_id_0730afc6-6112-40a9-9aff-ef598fac6f68">
               <id root="3a7e8f22-107d-4741-924b-1b2ca409ec62"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">(100,000 units per mL)</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">Rx only</content>
                  </paragraph>
               </text>
               <effectiveTime value="20100628"/>
