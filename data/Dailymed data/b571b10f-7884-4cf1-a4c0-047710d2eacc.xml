         <component>
            <section ID="ID47">
               <id root="ad88bbaa-b440-4f1a-81da-ccd9d7e9220c"/>
               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>PRINCIPAL DISPLAY PANEL  Bottle Label</title>
               <text>
                  <paragraph ID="ID48">
                     <content styleCode="bold">MGP</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">NDC 60432-528-04</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">6506-00-299-8671</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">SELENIUM SULFIDE</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">LOTION, USP 2.5%</content>
                  </paragraph>
                  <paragraph ID="ID76">
                     <content styleCode="bold">DESCRIPTION:</content> Selenium Sulfide Lotion, USP 2.5% is a </paragraph>
                  <paragraph>liquid antiseborrheic, antifungal preparation for topical</paragraph>
                  <paragraph> application, containing selenium sulfide 2.5% w/v in </paragraph>
                  <paragraph>aqueous suspension. <content styleCode="bold">Also contains:</content> Amphoteric-2;</paragraph>
                  <paragraph>Bentonite, NF; Captan; Citric Acid, USP; D&amp;C Yellow</paragraph>
                  <paragraph>#10; Ethylene Glycol Monostearate; Glyceryl</paragraph>
                  <paragraph>Monoricinoleate; Lauric Diethanolamide; Perfume;</paragraph>
                  <paragraph>Purified Water, USP; Sodium Lauryl Sulfate; Sodium</paragraph>
                  <paragraph>Phosphate Monobasic, USP and Titanium Dioxide, USP.</paragraph>
