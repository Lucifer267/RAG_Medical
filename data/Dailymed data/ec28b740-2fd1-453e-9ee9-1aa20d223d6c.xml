               <id root="d1017fd7-1b6d-4d2a-b661-57b1f60d6da8"/>
               <code code="42232-9" codeSystem="2.16.840.1.113883.6.1" displayName="PRECAUTIONS SECTION"/>
               <title>PRECAUTIONS</title>
               <text>
                  <paragraph>Do not use unless solution is clear and no leaks detected.</paragraph>
               </text>
               <effectiveTime value="20150209"/>
               <component>
                  <section ID="ID_c7ef69b3-d602-4351-8a90-8ab8bbbe8a2f">
