                     <code code="34072-9" codeSystem="2.16.840.1.113883.6.1" displayName="GENERAL PRECAUTIONS SECTION"/>
                     <title>General</title>
                     <text>
                        <paragraph>Rx only.  Discard unused portion.</paragraph>
                        <paragraph>Recommended Storage:  Store at room temperature (25°C / 77°F).</paragraph>
                     </text>
                     <effectiveTime value="20150209"/>
                  </section>
