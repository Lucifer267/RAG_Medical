               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>WARNINGS</title>
               <text>
                  <paragraph>Avoid excessive heat. Protect from freezing.</paragraph>
               </text>
               <effectiveTime value="20150209"/>
            </section>
         </component>
         <component>
