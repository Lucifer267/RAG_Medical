               <title>HOW SUPPLIED</title>
               <text>
                  <paragraph>750 mL volume bag.  </paragraph>
                  <paragraph>Each 100 ml contains:</paragraph>
                  <paragraph>0.73 g citric acid (anhydrous), USP</paragraph>
                  <paragraph>2.20 g sodium citrate (dihydrate), USP</paragraph>
                  <paragraph>2.45 g dextrose (monohydrate), USP</paragraph>
               </text>
               <effectiveTime value="20150209"/>
            </section>
