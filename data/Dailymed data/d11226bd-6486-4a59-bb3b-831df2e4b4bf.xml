               <component>
                  <section>
                     <id root="f9d89081-cce6-4f23-b6de-30f1bf1f5c56"/>
                     <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
                     <text>
                        <paragraph>Store at 25°C (77°F); excursions permitted to 15°C - 30°C (59° - 86°F). Protect from freezing. [See USP Controlled Room Temperature.]</paragraph>
