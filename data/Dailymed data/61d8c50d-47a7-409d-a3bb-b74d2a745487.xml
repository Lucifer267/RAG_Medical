                     <thead>
                        <tr>
                           <th styleCode="Lrule">BenzaClin</th>
                           <th styleCode="Lrule">Benzoyl peroxide</th>
                           <th styleCode="Lrule">Clindamycin</th>
                           <th styleCode="Lrule Rrule">Vehicle</th>
                        </tr>
                        <tr>
                           <th styleCode="Lrule">n=95</th>
