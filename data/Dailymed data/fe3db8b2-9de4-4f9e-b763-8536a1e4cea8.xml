                  <br/>
                  <paragraph>
                     <content styleCode="bold">Manufacturer:</content>
                     <br/> Macleods Pharmaceuticals Limited<br/> At Oxalis Labs<br/> Baddi, Himachal Pradesh, INDIA</paragraph>
                  <paragraph>Rev. 01/2021</paragraph>
                  <br/>
               </text>
               <effectiveTime value="20191128"/>
            </section>
