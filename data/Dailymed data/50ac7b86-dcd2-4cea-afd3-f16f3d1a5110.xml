               <code code="50569-3" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - ASK DOCTOR SECTION"/>
               <text>
                  <paragraph>IF CONDITION WORSENS, OR IF SYMPTOMS PERSIST FOR MORE THAN 7 DAYS OR CLEAR UP AND OCCUR AGAIN WITHIN A FEW DAYS, DISCONTINUE USE OF THIS PRODUCT AND CONSULT A DOCTOR.<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20130806"/>
            </section>
         </component>
