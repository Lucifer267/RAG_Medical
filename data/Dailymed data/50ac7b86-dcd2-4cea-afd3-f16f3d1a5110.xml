               <code code="50570-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - DO NOT USE SECTION"/>
               <text>
                  <paragraph>DO NOT USE:</paragraph>
                  <list listType="unordered">
                     <item>ON WOUNDS OR DAMAGED SKIN.</item>
                     <item>CHILDREN UNDER 12 YEARS OLD, CONSULT A DOCTOR.</item>
                     <item>IF YOU ARE ALLERGIC TO ANY INGREDIENTS IN THIS PRODUCT.</item>
                  </list>
               </text>
               <effectiveTime value="20130806"/>
            </section>
