         <component>
            <section ID="Le3d5d6d8-82e0-40f6-8e4e-52b45293ff58">
               <id root="d48e5de4-33a1-4622-8eac-8d63eb70bfaf"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <text>
                  <paragraph>WARNNGS:</paragraph>
                  <paragraph>FOR EXTERNAL USE ONLY.</paragraph>
                  <list listType="unordered">
                     <item>USE ONLY AS DIRECTED</item>
                     <item>AVOID CONTACT WITH EYES AND MUCOUS MEMBRANES</item>
                     <item>DO NOT USE WITH HEATING DEVICES OR PADS</item>
                     <item>DO NOT BANDAGE TIGHTLYIF SWALLOWED, CALL POISON CONTROL</item>
                     <item>IF CONTACT DOES OCCUR WITH EYES, RINSE WITH COLD WATER AND CALL A DOCTOR.</item>
                  </list>
               </text>
               <effectiveTime value="20130806"/>
            </section>
         </component>
