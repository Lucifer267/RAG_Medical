            <section>
               <id root="d46c6a1c-8d94-430e-b2df-c226847d8344"/>
               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>PRINCIPAL DISPLAY PANEL - 5 g Tube </title>
               <text>
                  <paragraph>
                     <content styleCode="bold">NDC 54868-2742-0</content>
                  </paragraph>
                  <paragraph>
                     <renderMultiMedia referencedObject="MM2"/>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">5 g</content>
                  </paragraph>
                  <paragraph>
