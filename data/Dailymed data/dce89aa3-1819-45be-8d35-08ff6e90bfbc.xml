               <text>
                  <paragraph>
                     <content styleCode="bold"/>Hydrocortisone acetate suppositories 25mg<br/>For Rectal Administration<br/>Rx Only</paragraph>
               </text>
               <effectiveTime value="20180305"/>
            </section>
