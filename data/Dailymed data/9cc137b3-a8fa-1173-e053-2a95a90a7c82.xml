         <component>
            <section ID="id_link_5c65be20-f950-72dc-e053-2a91aa0a10c6">
               <id root="9cc137b3-a8ff-1173-e053-2a95a90a7c82"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>Directions:</title>
               <text>
                  <paragraph>Application Directions:</paragraph>
                  <paragraph>For topical use only</paragraph>
                  <paragraph>For best results apply to previously dried oral mucosa with cotton swab or similar applicator for adequate control of pain</paragraph>
                  <paragraph>Removal of excess saliva during application minimizes dilution of the anesthetic and permits maximum penetration</paragraph>
                  <paragraph>Not more than 1.2 mg per Kg body weight per patient should be applied during a 24 hour period</paragraph>
               </text>
               <effectiveTime value="20170816"/>
            </section>
         </component>
         <component>
            <section ID="id_link_5c65d88a-7389-1f1c-e053-2a91aa0a2afb">
               <id root="9cc137b3-a8fb-1173-e053-2a95a90a7c82"/>
               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>Warnings</title>
               <text>
                  <paragraph>Warning:</paragraph>
                  <paragraph>Recommended dosage should not be exceeded due to possible side effects.</paragraph>
                  <paragraph>Keep out of the reach of children.</paragraph>
                  <paragraph>For professional use only.</paragraph>
                  <paragraph>Do not use in the eye.</paragraph>
                  <paragraph>Avoid swallowing.</paragraph>
                  <paragraph>Not for home or unsupervised consumer use.</paragraph>
                  <paragraph>Not for use on children 2 and younger or pregnant or nursing women.</paragraph>
               </text>
               <effectiveTime value="20170816"/>
            </section>
         </component>
         <component>
            <section ID="id_link_5c65bfe2-1a0e-59a5-e053-2a91aa0ad757">
               <id root="9cc137b3-a8fc-1173-e053-2a95a90a7c82"/>
               <code code="34070-3" codeSystem="2.16.840.1.113883.6.1" displayName="CONTRAINDICATIONS SECTION"/>
               <title>Contraindications</title>
               <text>
                  <paragraph>Precaine B is contraindicated in patients with known hypersensitivity to benzocaine or PABA</paragraph>
               </text>
               <effectiveTime value="20170816"/>
            </section>
