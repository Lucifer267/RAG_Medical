                           </td>
                        </tr>
                        <tr>
                           <td>Burning/Itching<br/>
                           </td>
                           <td>60 (11)<br/>
                           </td>
                           <td>#   (-)<br/>
                           </td>
                           <td>#   (-)<br/>
                           </td>
                        </tr>
                        <tr>
                           <td>Dryness<br/>
                           </td>
                           <td>105 (19)<br/>
                           </td>
                           <td>34 (23)<br/>
                           </td>
                           <td>29 (18)<br/>
                           </td>
                        </tr>
                        <tr>
                           <td>Erythema<br/>
                           </td>
                           <td>86 (16)<br/>
                           </td>
                           <td>10 (7)<br/>
                           </td>
                           <td>22 (14)<br/>
                           </td>
                        </tr>
                        <tr>
                           <td>Oilliness/Oily Skin<br/>
                           </td>
                           <td>8 (1)<br/>
                           </td>
                           <td>26 (18)<br/>
                           </td>
                           <td>12* (10)<br/>
                           </td>
                        </tr>
                        <tr>
                           <td>Peeling<br/>
                           </td>
                           <td>61 (11)<br/>
                           </td>
                           <td>#   (-)<br/>
