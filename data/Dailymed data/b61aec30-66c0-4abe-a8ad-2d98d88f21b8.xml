            <section ID="i4i_section_id_bb92837f-d146-49f0-997d-78f9eb1d92c8">
               <id root="fe1ad73e-cd0b-45d4-b355-e1d759907fc9"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
