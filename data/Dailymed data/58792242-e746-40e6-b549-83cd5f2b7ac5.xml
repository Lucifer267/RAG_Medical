         <component>
            <section>
               <id root="960780f5-6a31-4b0d-a044-5cbc16f1b67b"/>
               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>PRINCIPAL DISPLAY PANEL - 56 g Tube Carton</title>
               <text>
                  <paragraph>
                     <content styleCode="bold">FRESH MINT</content>
                     <br/>Rx ONLY<br/>NDC 60258-151-01</paragraph>
                  <paragraph>
                     <content styleCode="bold">SF 1.1% GEL</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="italics">1.1% SODIUM FLUORIDE</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="italics">Brush-on Gel (non-abrasive formula)</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">CYPRESS</content>
