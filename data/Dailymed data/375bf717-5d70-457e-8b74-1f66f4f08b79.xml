                  <br/>NeoBenz® <content styleCode="italics">Micro</content> Wash is supplied as follows:<br/>SIZE: 180 gram tottle<br/>NDC NUMBER:<br/>(benzoyl peroxide 7%): 67402-027-17<content>
                     <br/>
                     <br/>
                  </content>
               </text>
               <effectiveTime value="20090706"/>
            </section>
         </component>
         <component>
            <section>
               <id root="f2b92494-65fc-4c58-bcca-9213aad0a4f7"/>
               <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
               <text>
                  <content>Store between 15<sup>o</sup> - 25<sup>o</sup> C (59<sup>o</sup> - 77<sup>o</sup> F)</content>
                  <br/>
               </text>
               <effectiveTime value="20090706"/>
            </section>
         </component>
