            <section ID="s3">
               <id root="958d5bfa-83ce-400f-9d45-1e20169c41cb"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>Sterile, Preservative-Free
</paragraph>
               </text>
