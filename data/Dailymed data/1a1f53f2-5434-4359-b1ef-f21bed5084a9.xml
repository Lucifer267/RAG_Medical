            <section ID="i4i_section_id_b8af0e0f-c6f7-4093-9d23-ae324d469fcd">
               <id root="0805df76-0094-434a-96ab-77947b374a15"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
