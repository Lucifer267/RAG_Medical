            <section ID="s0">
               <id root="78dae1e0-ef9b-254d-1e4d-8158259058c7"/>
               <code code="34066-1" codeSystem="2.16.840.1.113883.6.1" displayName="BOXED WARNING SECTION"/>
               <text>
                  <paragraph ID="P1">
                     <content styleCode="bold">Warning:</content> Accidental
overdose of <content styleCode="bold">iron-containing</content> products is a leading cause
of fatal poisoning in children under 6. KEEP THIS PRODUCT OUT OF THE
REACH OF CHILDREN. In case of accidental overdose, call a doctor or
poison control center immediately.</paragraph>
               </text>
               <effectiveTime value="20140618"/>
            </section>
         </component>
