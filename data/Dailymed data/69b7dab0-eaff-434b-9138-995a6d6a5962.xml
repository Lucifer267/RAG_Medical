               <code code="43685-7" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS AND PRECAUTIONS SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">WARNINGS and PRECAUTIONS<br/>
                     </content>
                  </paragraph>
                  <paragraph>For external use only. <br/>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">When using this product</content> avoid contact with eyes. If contact occurs, rinse  throughly with water to remove.</paragraph>
                  <paragraph>
                     <content styleCode="bold">Stop use and consult a physician</content> if rash or irritation develops and lasts.</paragraph>
                  <paragraph>
                     <content styleCode="bold">Keep out of reach of children.</content> If swallowed, get medical help or contact Poison Control Center immediately.<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20110323"/>
            </section>
