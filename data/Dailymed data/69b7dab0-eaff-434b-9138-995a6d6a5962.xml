               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <text>
                  <paragraph>                <content styleCode="bold">USAGE</content>
                  </paragraph>
                  <list listType="unordered" ID="i1bad29a9-b452-456a-86ee-374955435cf9">
                     <item>Helps prevent sunburn</item>
                     <item>Apply liberally at least 20 minutes prior to sun exposure</item>
                     <item>Reapply as needed</item>
                     <item>For children under the age of 6 months please contact physician before use<br/>
                     </item>
                  </list>
               </text>
               <effectiveTime value="20110323"/>
            </section>
