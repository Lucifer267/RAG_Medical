               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <title>
                  <content styleCode="bold"/>
               </title>
               <text>
                  <paragraph>Dear Medical Professional, Per your order, we have compounded I-131 in Mini Cap form. The characteristics of this compound are:</paragraph>
               </text>
               <effectiveTime value="20120427"/>
            </section>
