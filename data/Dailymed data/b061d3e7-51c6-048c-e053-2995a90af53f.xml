               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <text>
                  <paragraph>
                     <caption styleCode="bold">Indications:</caption> To provide Vitamin and Mineral supplementation throughout pregnancy and during the postnatal period for both the lactating and nonlactating mother. It is also useful for improving nutritional status prior to conception.
      

 </paragraph>
               </text>
               <effectiveTime value="20200519"/>
            </section>
         </component>
         <component>
