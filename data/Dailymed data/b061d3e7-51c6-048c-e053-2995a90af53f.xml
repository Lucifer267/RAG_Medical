               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <text>
                  <paragraph>
                     <caption styleCode="bold">Directions:</caption> Before, during and after pregnancy, one tablet daily or as directed by a physician.
      

 </paragraph>
               </text>
               <effectiveTime value="20200519"/>
            </section>
         </component>
