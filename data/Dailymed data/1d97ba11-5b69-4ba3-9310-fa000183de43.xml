            <section ID="i4i_section_id_6347ebc8-4fd2-4861-804f-b5cd51ebd0c3">
               <id root="b6b65465-6159-43aa-8090-671ddc4d1ef2"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
