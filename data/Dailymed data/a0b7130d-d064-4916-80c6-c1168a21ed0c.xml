               </text>
               <effectiveTime value="20161215"/>
            </section>
         </component>
         <component>
            <section ID="La32cc597-4fed-42b0-a1cf-b18501c0fa58">
               <id root="f7a84b00-85e2-43b0-85c9-9d3383a34585"/>
               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>PACKAGE/LABEL PRINCIPAL DISPLAY PANEL – 100 mg 100ct</title>
               <text>
                  <paragraph>Flavoxate Hydrochloride Tablets, 100 mg</paragraph>
