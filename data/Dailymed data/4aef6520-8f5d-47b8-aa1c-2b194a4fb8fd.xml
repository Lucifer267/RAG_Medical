         <component>
            <section>
               <id root="7b5f3a4b-12b0-458b-adf1-8bb178ba01e0"/>
               <code code="34089-3" codeSystem="2.16.840.1.113883.6.1" displayName="DESCRIPTION SECTION"/>
               <title>DESCRIPTION</title>
               <text>
                  <paragraph>Contains lidocaine HCl 3% in a mild acidic vehicle. Lidocaine is chemically designated as acetamide, 2-(diethylamino)-N-(2,6-dimethylphenyl).</paragraph>
                  <renderMultiMedia referencedObject="MM1">
                     <caption>C<sub>14</sub>H<sub>22</sub>N<sub>2</sub>O                                               Mol. wt. 234.34</caption>
                  </renderMultiMedia>
                  <paragraph>
                     <content styleCode="bold">INGREDIENTS:</content> Each gram of <content styleCode="bold">Westminster Pharmaceuticals Lidocaine HCl 3% Cream</content> contains Lidocaine HCl USP 3% (30 mg).</paragraph>
                  <paragraph>Inactive ingredients include: Aluminum Sulfate, Calcium Acetate, Cetyl Alcohol, Methylparaben, Mineral Oil, Petrolatum, Polysorbate 80, Propylene Glycol, Propylparaben, Purified Water, Sodium Hydroxide, Sorbitan Monostearate, Stearic Acid, Stearyl Alcohol.</paragraph>
               </text>
               <effectiveTime value="20201130"/>
               <component>
                  <observationMedia ID="MM1">
                     <text>Chemical Structure</text>
                     <value xsi:type="ED" mediaType="image/jpeg">
                        <reference value="lidocaine-01.jpg"/>
                     </value>
                  </observationMedia>
               </component>
            </section>
