               <title>HOW SUPPLIED</title>
               <text>
                  <paragraph>Westminster Pharmaceuticals Lidocaine HCl 3% Cream</paragraph>
                  <paragraph>1 oz (28.35g) tube - NDC 69367-202-01<br/>3 oz (85 g) tube - NDC 69367-202-85</paragraph>
               </text>
               <effectiveTime value="20201130"/>
               <component>
                  <section>
                     <id root="899b7008-3171-44df-9cdc-9ba94587fde9"/>
                     <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
                     <title>STORAGE AND HANDLING</title>
                     <text>
                        <paragraph>Store at controlled room temperature 15° - 30°C (59° - 86°F). Avoid excessive heat and cold, Protect from sunlight and freezing.</paragraph>
                     </text>
                     <effectiveTime value="20201130"/>
                  </section>
               </component>
            </section>
