            </section>
         </component>
         <component>
            <section>
               <id root="84fde094-a346-4542-8fed-8c79f4b252c2"/>
               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>PRINCIPAL DISPLAY PANEL - 180 mL Bottle Carton</title>
               <text>
                  <paragraph>
                     <content styleCode="bold">NDC 42582-900-06</content>
                  </paragraph>
                  <paragraph>Rx Only</paragraph>
                  <paragraph>For topical use only<br/>Not for ophthalmic use</paragraph>
                  <paragraph>
                     <content styleCode="bold">Selenium<br/>Sulfide 2.25%<br/>Shampoo</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">180 mL</content>
