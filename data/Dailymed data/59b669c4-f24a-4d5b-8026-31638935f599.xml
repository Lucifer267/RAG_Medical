               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <title/>
               <text>
                  <paragraph>
                     <content styleCode="bold">CALL YOUR DOCTOR ABOUT SIDE EFFECTS.</content>
                     <br/>
                     <content styleCode="bold">Call your doctor about side effects. You may report side effects to Sterling Knight Pharmaceuticals, LLC at 1-888-460-1531 or the FDA at 1-800-FDA-1088.</content>
                  </paragraph>
               </text>
               <effectiveTime value="20180102"/>
            </section>
