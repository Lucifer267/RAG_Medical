         <component>
            <section>
               <id root="df34ddcc-7c8e-4cfc-82ff-47f567d6064d"/>
               <code code="59845-8" codeSystem="2.16.840.1.113883.6.1" displayName="INSTRUCTIONS FOR USE SECTION"/>
               <text>Directions:   <br/>Before, during and after pregnancy, one tablet and one enteric-coated softgel capsule taken by mouth daily, or as directed by a physician.<br/>
                  <br/>Use:  To provide vitamin and mineral supplementation throughout pregnancy and during the postnatal period for both the lactating and non lactating mother. It is also useful for improving nutritional status prior to conception. <br/>
                  <paragraph>
                     <br/> <br/>
                     <br/>
                  </paragraph>
               </text>
               <effectiveTime value="20120501"/>
            </section>
