               <title>
                  <content styleCode="bold">ACTIVE INGREDIENTS:</content>
               </title>
               <text>
                  <paragraph>
                     <content styleCode="bold">Active Ingredients: </content>
                  </paragraph>
                  <paragraph>1.23% w/w Fluoride Ion (0.79% from Sodium Fluoride and 0.44% from Hydrogen Fluoride) in 0.1 Molar Phosphoric Acid.</paragraph>
                  <paragraph>
                     <content styleCode="bold">Contains:</content> FD&amp;C Red #40.
 </paragraph>
               </text>
               <effectiveTime value="20150806"/>
            </section>
