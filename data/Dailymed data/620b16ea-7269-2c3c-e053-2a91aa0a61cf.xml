               <code code="51727-6" codeSystem="2.16.840.1.113883.6.1" displayName="INACTIVE INGREDIENT SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">OTHER INGREDIENTS:</content> Methocel K, stearic acid, magnesium stearate and silicon dioxide, dicalcium phosphate
      

 </paragraph>
               </text>
