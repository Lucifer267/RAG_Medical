               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>Suggested Dosage</title>
               <text>
                  <paragraph>One tablet daily taken away from meals, or as directed by the physician.</paragraph>
               </text>
               <effectiveTime value="20210714"/>
            </section>
