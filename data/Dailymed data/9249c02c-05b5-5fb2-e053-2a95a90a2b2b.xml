               <code code="60559-2" codeSystem="2.16.840.1.113883.6.1" displayName="COMPONENTS"/>
               <title>
                  <content styleCode="bold">C</content>
                  <content styleCode="bold">ONTENTS</content>
               </title>
               <text>
                  <paragraph>Hydroxyquinoline Sulfate 0.025%; Sodium Lauryl Sulfate N.F. 0.01%. Adjusted with Triethanolamine to pH 4 in water dispersible base composed of Glycerine, Carbomer N.F., Citric Acid, Sodium Citrate U.S.P., Methylparaben N.F., Perfume and Antifoam Emulsion N.F.</paragraph>
               </text>
               <effectiveTime value="20190911"/>
            </section>
