               <id root="f15d02b9-58fb-4767-b5cd-e7f1f567e922"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="55106-9" displayName="OTC - ACTIVE INGREDIENT SECTION"/>
               <title/>
               <effectiveTime value="20100302"/>
               <component>
                  <section>
                     <id root="5ce90a4f-121f-4a02-8695-8e94dbaa13e3"/>
                     <code codeSystem="2.16.840.1.113883.6.1" code="55105-1" displayName="OTC - PURPOSE SECTION"/>
                     <title/>
                     <text>
                        <table width="60%">
                           <col width="50%" align="left"/>
                           <col width="50%" align="right"/>
                           <tbody>
                              <tr styleCode="Toprule">
                                 <td>
                                    <content styleCode="bold italics">Active ingredients (in each extended-release bi-layer tablet)</content>
                                 </td>
                                 <td>
                                    <content styleCode="bold italics">Purpose</content>
                                 </td>
                              </tr>
                              <tr>
                                 <td>Guaifenesin 600 mg</td>
                                 <td>Expectorant</td>
                              </tr>
                              <tr styleCode="Botrule">
                                 <td>Pseudoephedrine HCl 60 mg</td>
                                 <td>Nasal Decongestant</td>
                              </tr>
                           </tbody>
                        </table>
                     </text>
                  </section>
               </component>
            </section>
