               <title>Other information</title>
               <text>
                  <list listType="unordered" styleCode="square">
                     <item>tamper evident: do not use if carton is open or if printed seal on blister is broken or missing</item>
                     <item>store at 20-25°C (68-77°F)</item>
                  </list>
               </text>
               <effectiveTime value="20100302"/>
            </section>
