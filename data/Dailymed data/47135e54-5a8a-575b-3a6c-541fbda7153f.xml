         <component>
            <section ID="_edc4d307-9b9e-3f35-fdb6-a6615129e124">
               <id root="75ba1dd4-f6cb-751a-b824-bf4c84b70bcf"/>
               <code code="44425-7" displayName="STORAGE AND HANDLING SECTION" codeSystem="2.16.840.1.113883.6.1"/>
               <title>STORAGE:</title>
               <text>
                  <paragraph>Store Cloderm Cream between 15° and 30° C (59° and 86° F). Avoid freezing.</paragraph>
               </text>
               <effectiveTime value="20120125"/>
            </section>
