               <component>
                  <section ID="LINK_4a1f2409-9061-44f3-82b7-582d54833b0d">
                     <id root="1835e604-2714-4063-801c-a6241633ea89"/>
                     <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
                     <title/>
                     <text>
                        <paragraph>Exposure of pharmaceutical products to heat should be minimized. Avoid excessive heat. Protect from freezing. It is recommended that the product be stored at room temperature (25°C); however, brief exposure up to 40°C does not adversely affect the product.</paragraph>
                     </text>
                     <effectiveTime value="20210806"/>
                  </section>
