               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>OXYGEN COMPRESSED LABEL</title>
               <text>
                  <paragraph>OXYGEN COMPRESSED U.S.P.  UN 1072 OXYGEN-2</paragraph>
                  <paragraph>WARNING: SECURE ALL CYLINDERS WHILE IN STORAGE AND IN USE.  FOR EMERGENCY USE ONLY WHEN ADMINISTERED BY PROPERLY TRAINED PERSONNEL FOR OXYGEN DEFICIENCY AND RESUSCITATION.  FOR ALL OTHER MEDICAL APPLICATIONS Rx ONLY.  USE ONLY WITH PRESSURE REDUCING EQUIPMENT AND APPARATUS DESIGNED FOR OXYGEN.  USE IN ACCORDANCE WITH MATERIAL SAFETY DATA SHEET AND SAFETY PRECAUTIONS RECOMMENDED BY SUPPLIER.  PRODUCED BY AIR LIQUEFACTION.  <br/>
                  </paragraph>
                  <paragraph>
                     <renderMultiMedia referencedObject="CRANWSOX1"/>
                  </paragraph>
               </text>
               <effectiveTime value="20100101"/>
               <component>
                  <observationMedia classCode="OBS" moodCode="EVN" ID="CRANWSOX1">
                     <text>HP LABEL</text>
                     <value xsi:type="ED" mediaType="image/jpeg">
                        <reference value="cranston_hp_ox.jpg"/>
                     </value>
                  </observationMedia>
               </component>
            </section>
         </component>
