               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <title>
                  <content styleCode="bold"/>
               </title>
               <text>
                  <paragraph>Dear Medical Professional,</paragraph>
                  <paragraph>Per your order, we have compounded Tetrofosmin as a sterile, freeze-dried preparation in a 10 mL vial. The characteristics of this preparation are described below.</paragraph>
               </text>
               <effectiveTime value="20120426"/>
            </section>
