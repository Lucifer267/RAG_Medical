                              <content styleCode="bold">*Osmolarity</content>
                              <br/>
                              <content styleCode="bold">(mOsmol/L)</content>
                              <br/>
                              <content styleCode="bold">(calc)</content>
                           </td>
                           <td rowspan="2" align="center" valign="bottom" styleCode="Toprule Botrule Rrule">
                              <content styleCode="bold">pH</content>
                           </td>
                        </tr>
                        <tr>
                           <td align="center" valign="top" styleCode="Botrule Rrule">
                              <content styleCode="bold">Sodium</content>
                              <br/>
