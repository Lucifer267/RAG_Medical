         <component>
            <section>
               <id root="24a36fb2-5743-4d65-9537-c764767f4cd9"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>DOSAGE AND ADMINISTRATION SECTION</title>
               <text>
                  <paragraph>DIRECTIONS FOR USE:</paragraph>
                  <paragraph>1. DISPENSE 10ML OF SOLUTION INTO A MEASURING CUP.</paragraph>
                  <paragraph>2. INSTRUCT PATIENT TO RINSE VIGOROUSLY FOR I MINUTE AND THEN EXPECTORATE.</paragraph>
                  <paragraph>3. FOR MAXIMUM BENEFIT, HAVE PATIENT REPEAT PROCEDURE WITH AN ADDITIONAL 10ML.</paragraph>
                  <paragraph>4. DO NOT EAT OR DRINK FOR 30 MINUTES AFTER USE.<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20111018"/>
            </section>
         </component>
