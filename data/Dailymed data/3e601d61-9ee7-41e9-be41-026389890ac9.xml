               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>WARNINGS SECTION</title>
               <text>
                  <paragraph>CAUTIONS AND WARNINGS: FOR PROFESSIONAL USE ONLY. DO NOT SWALLOW. US LAW PROHIBITS DISPENSING WITHOUT PRESCRIPTION.<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20111018"/>
            </section>
