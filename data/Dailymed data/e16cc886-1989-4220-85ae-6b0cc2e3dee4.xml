                  <paragraph>                                NDC 0168-0273-38                                3.5 gram tubes</paragraph>
                  <paragraph>Store between 15° and 25°C (59° and 77°F).</paragraph>
                  <paragraph>
                     <content styleCode="bold">E. FOUGERA &amp; CO.</content>
                  </paragraph>
                  <paragraph>A division of Nycomed US Inc.<br/>MELVILLE, NEW YORK 11747</paragraph>
                  <paragraph>I273A<br/>R10/07</paragraph>
               </text>
               <effectiveTime value="20090508"/>
            </section>
         </component>
