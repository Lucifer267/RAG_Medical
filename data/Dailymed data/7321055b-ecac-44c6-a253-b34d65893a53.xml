                  </table>
                  <br/>
               </text>
               <effectiveTime value="20110510"/>
               <component>
                  <section>
                     <id root="26aa8b4a-0995-4641-952e-f819ace97103"/>
                     <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
                     <title>STORAGE</title>
                     <text>
                        <paragraph>Store at controlled room temperature 15°-30°C (59°-86°F); avoid excessive heat (40°C;104°F).</paragraph>
                     </text>
                     <effectiveTime value="20100825"/>
                  </section>
               </component>
