         <component>
            <section>
               <id root="7ec17939-0a16-4a51-bd60-b7a114ba7a2e"/>
               <code code="34089-3" codeSystem="2.16.840.1.113883.6.1" displayName="DESCRIPTION SECTION"/>
               <title>DESCRIPTION</title>
               <text>
                  <paragraph>Wentworth Sodium Fluoride Rinse 0.2% of neutral sodium fluoride is a mint-flavored, neutral, aqueous solution.</paragraph>
               </text>
               <effectiveTime value="20210426"/>
               <component>
                  <section>
                     <id root="99185054-69de-4aa8-bc75-e0d7d31be97a"/>
                     <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
                     <title>Active Ingredient</title>
                     <text>
                        <paragraph>Sodium Fluoride 0.2% (w/v)</paragraph>
                     </text>
                     <effectiveTime value="20210323"/>
                  </section>
               </component>
               <component>
                  <section>
                     <id root="a6c8e3c4-a7ea-4ef2-b0d3-12de622d47e3"/>
                     <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
                     <title>Inactive Ingredients</title>
                     <text>
                        <paragraph>benzoic acid, flavor, glycerin, poloxamer 338, propylene glycol, sodium benzoate, water, FD&amp;C Blue No. 1</paragraph>
                     </text>
                     <effectiveTime value="20210415"/>
                  </section>
