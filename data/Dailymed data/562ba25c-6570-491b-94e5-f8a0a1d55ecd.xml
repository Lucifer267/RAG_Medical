               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <text>
                  <paragraph>                           <content styleCode="bold"> USES</content>
                  </paragraph>
                  <list listType="unordered" ID="i94485320-0bb0-4bf4-8888-7f9fead612d8">
                     <item>Helps prevent sunburns</item>
                     <item>Higher SPF gives more sunburn protection</item>
                     <item>Apply liberally as needed 15 to 20 minutes before sun exposure</item>
                     <item>Reapply as needed or after swimming, perspiring or towel drying</item>
                     <item>Children under 6 months of age: ask doctor<br/>
                     </item>
                  </list>
               </text>
               <effectiveTime value="20100706"/>
            </section>
