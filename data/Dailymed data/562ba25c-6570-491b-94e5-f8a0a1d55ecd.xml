               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <text>
                  <paragraph>WARNINGS</paragraph>
                  <paragraph>For external use only. When using this product keep out of eyes. Rinse with water to remove. Stop use and ask a doctor if rash or irritation develops and lasts. Keep out of reach of children. If swallowed, get medical help or contact Poison Center right away.<br/>
                  </paragraph>
                  <paragraph>
                     <br/>
                  </paragraph>
               </text>
               <effectiveTime value="20100706"/>
            </section>
