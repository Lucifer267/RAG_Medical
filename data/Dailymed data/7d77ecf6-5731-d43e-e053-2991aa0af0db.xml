         <component>
            <section ID="s8">
               <id root="7d77ecf6-5739-d43e-e053-2991aa0af0db"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>Directions
</title>
               <text>
                  <paragraph>For adults and children two-years or older, apply externally to the affected area. Do not use more than three to four times per day.
</paragraph>
               </text>
               <effectiveTime value="20160914"/>
            </section>
         </component>
