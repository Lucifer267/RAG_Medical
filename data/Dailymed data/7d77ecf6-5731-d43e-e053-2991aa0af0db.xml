                     <id root="7d77ecf6-5738-d43e-e053-2991aa0af0db"/>
                     <code code="50565-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - KEEP OUT OF REACH OF CHILDREN SECTION"/>
                     <text>
                        <paragraph>
                           <content styleCode="bold">Keep out of reach of children.</content> If swallowed, get medical help or contact a Poison Control Center right away.

        

 </paragraph>
                     </text>
                     <effectiveTime value="20160914"/>
                  </section>
