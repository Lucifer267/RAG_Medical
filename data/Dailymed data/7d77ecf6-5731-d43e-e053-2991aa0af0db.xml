               <code code="34071-1" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS SECTION"/>
               <title>Warning
</title>
               <text>
                  <paragraph>For external use only.
</paragraph>
                  <paragraph>Avoid contact with eyes
</paragraph>
               </text>
               <effectiveTime value="20160914"/>
               <component>
                  <section ID="s6">
                     <id root="7d77ecf6-5737-d43e-e053-2991aa0af0db"/>
                     <code code="50566-9" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - STOP USE SECTION"/>
                     <title>Stop using this product and ask doctor if
</title>
                     <text>
                        <list listType="unordered" styleCode="Disc">
                           <item>symptoms last for more than seven days, or clear up and occur again within a few days
</item>
                           <item>if redness, irritation, swelling, pain or other symptoms increase
</item>
                        </list>
                     </text>
                     <effectiveTime value="20160914"/>
                  </section>
               </component>
               <component>
