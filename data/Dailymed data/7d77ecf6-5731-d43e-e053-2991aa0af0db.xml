            <section ID="s4">
               <id root="7d77ecf6-5735-d43e-e053-2991aa0af0db"/>
               <code code="34067-9" codeSystem="2.16.840.1.113883.6.1" displayName="INDICATIONS &amp; USAGE SECTION"/>
               <title>Uses
</title>
               <text>
                  <paragraph>For temporary relief of pain and itching and minor skin irritations due to minor cuts and scrapes, sunburns, and minor burns.
</paragraph>
               </text>
               <effectiveTime value="20160914"/>
            </section>
         </component>
