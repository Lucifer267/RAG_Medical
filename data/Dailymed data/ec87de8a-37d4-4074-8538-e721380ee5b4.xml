               <id root="9b2bf352-f39d-4896-a522-54a68be6174e"/>
               <code code="50565-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - KEEP OUT OF REACH OF CHILDREN SECTION"/>
               <title>Keep out of reach of children </title>
               <text>
                  <paragraph>Keep out of reach of children. If swallowed get medical help or contact Poison Control right away.<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20111121"/>
            </section>
         </component>
         <component>
            <section>
               <id root="92eb8d3e-4a0e-4356-acf1-c2577cca36da"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <title>Directions</title>
               <text>
                  <list listType="unordered" ID="i1868e332-9640-4a2a-8243-757116965794">
                     <item>apply liberally before sun exposure and as needed</item>
                     <item>children under 6 months of age: ask doctor<br/>
                     </item>
                  </list>
               </text>
               <effectiveTime value="20111121"/>
            </section>
         </component>
         <component>
            <section>
               <id root="d4117633-d4cb-48f7-ae70-34e561b33d77"/>
               <code code="34072-9" codeSystem="2.16.840.1.113883.6.1" displayName="GENERAL PRECAUTIONS SECTION"/>
               <title>Sun Alert</title>
               <text>
                  <paragraph>Other information</paragraph>
                  <paragraph>Sun alert: limiting sun exposure, wearing protective clothing, and using sunscreen may reduce the risk of skin cancer, and other harmful effects of the sun.<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20111121"/>
            </section>
