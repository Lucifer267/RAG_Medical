               <code code="50566-9" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - STOP USE SECTION"/>
               <title>Stop use</title>
               <text>
                  <paragraph>Stop use and ask a doctor if rash and irritation develops and lasts<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20111121"/>
            </section>
         </component>
