               <title>Purpose</title>
               <text>
                  <list listType="unordered" ID="i214fb5a3-b1ba-4453-8eeb-ae87bc57318c">
                     <item>lip moisturizer</item>
                     <item>helps prevent sunburn</item>
                     <item>higher SPF gives more sunburn protection<br/>
                     </item>
                  </list>
               </text>
               <effectiveTime value="20111121"/>
            </section>
