               <code code="50567-7" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - WHEN USING SECTION"/>
               <title>When using tis product</title>
               <text>
                  <paragraph>When using this product keep out of eyes. Rinse with water remove.<br/>
                  </paragraph>
               </text>
               <effectiveTime value="20111121"/>
            </section>
