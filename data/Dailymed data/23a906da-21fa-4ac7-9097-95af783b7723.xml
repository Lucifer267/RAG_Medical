            <section ID="i4i_section_id_545e8ca4-fc4b-4724-9627-2f3c3d1041f4">
               <id root="dc6a4771-a4ce-4a43-84c1-eba80aa134cb"/>
               <code codeSystem="2.16.840.1.113883.6.1" code="42229-5" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">Rx only</content>
                  </paragraph>
