            <section ID="L57a2254a-81e4-4a24-a1f0-5d1f888e51aa">
               <id root="07eaac2c-609b-578b-e054-00144ff8d46c"/>
               <code code="43685-7" codeSystem="2.16.840.1.113883.6.1" displayName="WARNINGS AND PRECAUTIONS SECTION"/>
               <title>Warnings</title>
               <text>
                  <paragraph>For external use only</paragraph>
                  <paragraph>Avoid contact with eyes</paragraph>
                  <paragraph>Do not applly to open wounds or damaged skin</paragraph>
                  <paragraph>If symptoms persist for more than seven days, discontinue use and consult physician</paragraph>
                  <paragraph>If swallowed, consult physician</paragraph>
                  <paragraph>Do not bandage tightly</paragraph>
                  <paragraph>If pregnant or breast feeding, contact physician prior to use</paragraph>
                  <paragraph>Do not use in large quantities, particularly over raw surfaces or blistered areas</paragraph>
                  <paragraph/>
               </text>
               <effectiveTime value="20141117"/>
            </section>
         </component>
