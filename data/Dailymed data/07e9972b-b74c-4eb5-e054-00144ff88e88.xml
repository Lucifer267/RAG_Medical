         <component>
            <section ID="Lc2d849b6-e1ba-4eaf-b4e7-fd231f14b49e">
               <id root="07eaac2c-609f-578b-e054-00144ff8d46c"/>
               <code code="34068-7" codeSystem="2.16.840.1.113883.6.1" displayName="DOSAGE &amp; ADMINISTRATION SECTION"/>
               <text>
                  <paragraph>clean and dry affected area</paragraph>
                  <paragraph>remove patch from backing and apply to affected area</paragraph>
                  <paragraph>use only one patch at a time, and maximum of four patches/day</paragraph>
                  <paragraph>leave patch on affected area for up to 8 hours</paragraph>
                  <paragraph>do not use patches for longer than five consecutive days</paragraph>
                  <paragraph>children under 12 should consult physician prior to use</paragraph>
               </text>
               <effectiveTime value="20141117"/>
            </section>
         </component>
         <component>
