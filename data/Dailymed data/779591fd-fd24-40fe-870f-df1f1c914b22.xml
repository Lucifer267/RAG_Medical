               <title>HOW SUPPLIED</title>
               <text>
                  <paragraph>Bottles of 30 capsules each -<content styleCode="bold"> NDC </content>0178-0799-30.</paragraph>
               </text>
               <effectiveTime value="20110603"/>
            </section>
