               <code code="53413-1" codeSystem="2.16.840.1.113883.6.1" displayName="OTC - QUESTIONS SECTION"/>
               <title>Questions or Comments?</title>
               <text>
                  <paragraph>Call 1-800-SafeSun, Mon-Fri</paragraph>
               </text>
               <effectiveTime value="20121003"/>
            </section>
