               <code code="60561-8" codeSystem="2.16.840.1.113883.6.1" displayName="OTHER SAFETY INFORMATION"/>
               <title>Information</title>
               <text>
                  <paragraph>For product MSDS information please see company website at pascaldental.com or contact Pascal directly.</paragraph>
                  <paragraph>60 Second Taste is free of gluten, soy, milk, egg, peanut and tree nut products.</paragraph>
                  <paragraph>Rx Only in USA. For Professional Use only.</paragraph>
               </text>
               <effectiveTime value="19880401"/>
            </section>
         </component>
