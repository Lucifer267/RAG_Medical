            <section>
               <id root="914e8616-114a-42f3-9b27-354b3d58a655"/>
               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>PRINCIPAL DISPLAY PANEL - 51 g Tube Carton</title>
               <text>
                  <paragraph>
                     <content styleCode="bold">SPEARMINT</content>
                  </paragraph>
                  <paragraph>Rx ONLY</paragraph>
                  <paragraph>NDC 60258-150-01</paragraph>
                  <paragraph>
                     <content styleCode="bold">SF 5000 <content styleCode="italics">PLUS</content>
                     </content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="italics">1.1% SODIUM FLUORIDE Prescription Dental Cream</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="italics">5000 ppm Fluoride Plus Mild Cleaning System</content>
