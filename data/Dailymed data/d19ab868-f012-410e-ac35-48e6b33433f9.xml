            <section ID="ID_effe9d09-2682-4047-bd0d-8b6038dbe7a5">
               <id root="d2b177fd-9cfa-4af7-92fb-f8f66858e28a"/>
               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">PRESCRIBING INFORMATION</content>
                  </paragraph>
               </text>
               <effectiveTime value="20140724"/>
            </section>
