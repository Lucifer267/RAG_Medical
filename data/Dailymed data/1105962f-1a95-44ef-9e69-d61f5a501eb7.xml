         </component>
         <component>
            <section>
               <id root="2d44af85-5ddd-4084-b658-34b6e7b0c687"/>
               <code code="51945-4" codeSystem="2.16.840.1.113883.6.1" displayName="PACKAGE LABEL.PRINCIPAL DISPLAY PANEL"/>
               <title>PRINCIPAL DISPLAY PANEL - 227 g Bottle Label</title>
               <text>
                  <paragraph>
                     <content styleCode="bold">NDC</content> 42582-800-08<br/>
                     <content styleCode="bold">Rx Only</content>
