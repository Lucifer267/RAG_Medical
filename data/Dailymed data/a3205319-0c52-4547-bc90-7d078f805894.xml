         <component>
            <section ID="L2f44cfd8-fccd-466c-8f03-57eeb7b74a1e">
               <id root="53bb39e9-f471-44a1-a9a7-1df8659e3603"/>
               <code code="34089-3" codeSystem="2.16.840.1.113883.6.1" displayName="DESCRIPTION SECTION"/>
               <title>DESCRIPTION</title>
               <text>
                  <paragraph>Avant Fluoride Oral Rinse is a flavored, pH neutral 2.0% sodium fluoride treatment rinse that aids in the prevention of dental decay.</paragraph>
                  <paragraph>ACTIVE INGREDIENT: Sodium Fluoride, 2.0%</paragraph>
                  <paragraph>INACTIVE INGREDIENTS: Flavor, Water, Sodium Benzoate, Sodium Citrate, Saccharin Sodium, Xylitol</paragraph>
               </text>
               <effectiveTime value="20210124"/>
            </section>
         </component>
         <component>
            <section ID="L422631d5-86c8-419c-84bd-1cc69b11f1e7">
               <id root="3e4ea94c-f450-4d62-93b8-49820e6a25e2"/>
               <code code="34069-5" codeSystem="2.16.840.1.113883.6.1" displayName="HOW SUPPLIED SECTION"/>
               <title>HOW SUPPLIED/STORAGE</title>
               <text>
                  <paragraph>64 fluid ounces (1.9 L) in a plastic bottle with dispensing pump included. Store at room temperature 59-86°F (15-30°C). Protect from freezing.</paragraph>
               </text>
               <effectiveTime value="20210124"/>
            </section>
         </component>
