               <code code="34084-4" codeSystem="2.16.840.1.113883.6.1" displayName="ADVERSE REACTIONS SECTION"/>
               <title>ADVERSE REACTIONS</title>
               <text>
                  <paragraph>To report suspected adverse reactions, contact Dharma Research, Inc. at 1-877-833-3725 or the FDA at 1-800-FDA-1088 or www.fda.gov/medwatch</paragraph>
               </text>
