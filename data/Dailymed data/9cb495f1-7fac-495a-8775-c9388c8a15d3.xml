               <component>
                  <section>
                     <id root="f6692ef6-4407-45bc-9789-a5613825315c"/>
                     <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
                     <title>STORAGE</title>
                     <text>
                        <paragraph>Store at room temperature 15º-30ºC (59º-86ºF).</paragraph>
                        <paragraph>Keep tightly closed.</paragraph>
