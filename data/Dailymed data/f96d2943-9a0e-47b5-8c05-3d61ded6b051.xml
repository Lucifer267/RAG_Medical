         <component>
            <section>
               <id root="7c0710af-60ca-448b-91ef-8425e300edf5"/>
               <code code="34089-3" codeSystem="2.16.840.1.113883.6.1" displayName="DESCRIPTION SECTION"/>
               <title>DESCRIPTION</title>
               <text>
                  <paragraph>Naftin<sup>®</sup> Gel, 1% contains the synthetic, broad-spectrum, antifungal agent naftifine hydrochloride. Naftin<sup>®</sup> Gel, 1% is for topical use only.</paragraph>
               </text>
               <effectiveTime value="20090805"/>
               <component>
                  <section>
                     <id root="4f271d4a-5bd1-48fa-bb2b-557c7eec2073"/>
                     <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
                     <title>Chemical Name</title>
                     <text>
                        <paragraph>(E)-N-Cinnamyl-N-methyl-1-naphthalenemethylamine hydrochloride.</paragraph>
                        <paragraph>Naftifine hydrochloride has an empirical formula of C<sub>21</sub>H<sub>21</sub>N•HCl and a molecular weight of 323.86.</paragraph>
                        <renderMultiMedia referencedObject="MM1"/>
                     </text>
                     <effectiveTime value="20090805"/>
                  </section>
               </component>
               <component>
                  <section>
                     <id root="f6ccf85a-3e1d-4877-9173-2d48878ba1df"/>
                     <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
                     <title>Contains</title>
                     <text>
                        <table width="50%" ID="iaf553cf9-8fad-485f-89f6-2a701f7cef89">
