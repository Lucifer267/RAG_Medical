               <code code="42230-3" codeSystem="2.16.840.1.113883.6.1" displayName="SPL PATIENT PACKAGE INSERT SECTION"/>
               <title>Package Insert<br/>ZITHRANOL-RR anthralin microcrystalline encapsulated cream, 1.2%</title>
               <effectiveTime value="20100129"/>
               <component>
                  <section ID="s5">
                     <id root="8399d865-0151-4752-91fd-3f85d387e19e"/>
                     <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
