               <code code="42229-5" codeSystem="2.16.840.1.113883.6.1" displayName="SPL UNCLASSIFIED SECTION"/>
               <title/>
               <text>
                  <paragraph>Prenatal Multivitamin/<br/>Multimineral Tablets<br/>63044-154-63</paragraph>
                  <paragraph>Rx Only</paragraph>
                  <table frame="void" width="590">
                     <caption/>
                     <tbody>
                        <tr>
                           <td styleCode="BotruleLruleToprule" align="left" valign="top">
                              <content styleCode="bold">WARNING:</content> Accidental overdose of iron-containing prod-Ucts is a leading cause of fatal poisoning in children under 6. Keep this product out of the reach of children. In case of accidental overdose, call a doctor or poison control center immediately.</td>
                           <td styleCode="BotruleRruleToprule" align="left" valign="top"/>
                        </tr>
                     </tbody>
                  </table>
               </text>
               <effectiveTime value="20091218"/>
            </section>
