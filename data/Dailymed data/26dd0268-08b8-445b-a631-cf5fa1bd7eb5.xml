               <code code="44425-7" codeSystem="2.16.840.1.113883.6.1" displayName="STORAGE AND HANDLING SECTION"/>
               <text>
                  <paragraph>
                     <content styleCode="bold">STORE AT CONTROLLED ROOM TEMPERATURE 15°-30°C (59°-86°F). AVOID EXCESS HEAT. Dispense in a well closed light-resistant container, with a child resistant cap.</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">This medical food product is formulated to be administered orally, under the supervision of a physician.</content>
                  </paragraph>
                  <paragraph>
                     <content styleCode="bold">KEEP THIS AND ALL MEDICATIONS OUT OF THE REACH OF CHILDREN.</content>
                  </paragraph>
               </text>
               <effectiveTime value="20170530"/>
            </section>
